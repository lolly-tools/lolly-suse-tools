{
  "id": "meeting-planner",
  "name": "Meeting Planner",
  "description": "Plan a global meeting and see the time for every teammate's timezone.",
  "version": "1.0.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "event",
  "tags": ["map", "team", "timezone", "world", "time", "meeting", "schedule", "planner", "clock", "widget", "d3"],
  "examples": [
    { "label": "SUSECON · green · orthographic", "values": { "eventName": "SUSECON 2026", "city": "Orlando", "theme": "green", "layout": "landscape", "projection": "geoOrthographic", "showNight": true, "people": [ { "name": "Amina", "city": "Nuremberg" }, { "name": "Diego", "city": "São Paulo" }, { "name": "Mei", "city": "Singapore" }, { "name": "Sam", "city": "San Francisco" } ] } },
    { "label": "Global standup · dark · natural earth", "values": { "eventName": "Global Engineering Standup", "city": "Nuremberg", "theme": "dark", "layout": "landscape", "projection": "geoNaturalEarth1", "showBorders": true, "showGraticule": true, "people": [ { "name": "Lena", "city": "Berlin" }, { "name": "Ravi", "city": "Bengaluru" }, { "name": "Kenji", "city": "Tokyo" }, { "name": "Ana", "city": "Madrid" } ] } },
    { "label": "Release sync · light · equal earth", "values": { "eventName": "SLES 16 Release Sync", "city": "Prague", "theme": "light", "layout": "square", "projection": "geoEqualEarth", "landColor": "#eafaf1", "pinColor": "#30ba78", "people": [ { "name": "Tomáš", "city": "Prague" }, { "name": "Grace", "city": "London" }, { "name": "Omar", "city": "Dubai" } ] } },
    { "label": "Live world clock · green · mercator", "values": { "eventName": "Team World Clock", "city": "Nuremberg", "liveClock": true, "theme": "green", "layout": "portrait", "projection": "geoMercator", "people": [ { "name": "Sofia", "city": "Buenos Aires" }, { "name": "Yuki", "city": "Tokyo" }, { "name": "Ivan", "city": "Moscow" }, { "name": "Mary", "city": "New York" } ] } },
    { "label": "Community call · dark · azimuthal", "values": { "eventName": "Cloud Native Community Call", "city": "Amsterdam", "theme": "dark", "layout": "landscape", "projection": "geoAzimuthalEqualArea", "pinShape": "diamond", "pinColor": "#0a9bd6", "people": [ { "name": "Noah", "city": "Amsterdam" }, { "name": "Priya", "city": "Mumbai" }, { "name": "Chen", "city": "Shanghai" } ] } },
    { "label": "Edge summit · light · equirectangular", "values": { "eventName": "Edge Summit Planning", "city": "Munich", "theme": "light", "layout": "landscape", "projection": "geoEquirectangular", "pinColor": "#fe7c3f", "pinShape": "square", "people": [ { "name": "Elena", "city": "Munich" }, { "name": "Carlos", "city": "Mexico City" }, { "name": "Aisha", "city": "Nairobi" } ] } }
  ],
  "render": {
    "width": 800,
    "height": 600,
    "formats": ["png", "jpeg", "svg", "ics", "json"],
    "actions": ["copy", "download", "save"],
    "transparentBg": false
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "eventName",
      "label": "Event name",
      "type": "text",
      "default": "",
      "placeholder": " "
    },
    {
      "id": "titleWeight",
      "label": "Title weight",
      "type": "number",
      "display": "slider",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 500,
      "help": "Font weight of the event title (100 Thin → 900 Black)."
    },
    {
      "id": "city",
      "label": "Host city",
      "type": "text",
      "default": "Nuremberg",
      "placeholder": "e.g. Nuremberg",
      "help": "The city where the meeting originates — sets the timezone for the time below."
    },
    {
      "id": "meetingTime",
      "label": "Meeting date & time",
      "type": "datetime-local",
      "default": "",
      "help": "Local date and time in the host city. Ignored while Live clock is on."
    },
    {
      "id": "liveClock",
      "label": "Live clock",
      "type": "boolean",
      "default": false,
      "help": "Show the current time everywhere and keep ticking — leave it open as a world-clock widget."
    },
    {
      "id": "theme",
      "label": "Theme",
      "type": "select",
      "default": "dark",
      "options": [
        { "value": "dark",  "label": "Dark" },
        { "value": "light", "label": "Light" },
        { "value": "green", "label": "SUSE Green" }
      ]
    },
    {
      "id": "layout",
      "label": "Layout",
      "type": "select",
      "default": "landscape",
      "options": [
        { "value": "landscape", "label": "Landscape" },
        { "value": "portrait",  "label": "Portrait" },
        { "value": "square",    "label": "Square" }
      ]
    },
    {
      "id": "projection",
      "label": "Map projection",
      "type": "select",
      "group": "map",
      "default": "geoOrthographic",
      "options": [
        { "value": "geoNaturalEarth1",      "label": "Natural Earth" },
        { "value": "geoEqualEarth",         "label": "Equal Earth" },
        { "value": "geoMercator",           "label": "Mercator" },
        { "value": "geoOrthographic",       "label": "Orthographic" },
        { "value": "geoAzimuthalEqualArea", "label": "Azimuthal Equal Area" },
        { "value": "geoEquirectangular",    "label": "Equirectangular" },
        { "value": "geoStereographic",      "label": "Stereographic" }
      ]
    },
    {
      "id": "showNight",
      "label": "Night overlay",
      "type": "boolean",
      "group": "map",
      "default": true
    },
    {
      "id": "showGraticule",
      "label": "Graticule lines",
      "type": "boolean",
      "group": "map",
      "default": false
    },
    {
      "id": "showBorders",
      "label": "Country borders",
      "type": "boolean",
      "group": "map",
      "default": false
    },
    {
      "id": "landColor",
      "label": "Land color",
      "type": "color",
      "group": "map",
      "default": ""
    },
    {
      "id": "oceanColor",
      "label": "Ocean color",
      "type": "color",
      "group": "map",
      "default": "transparent"
    },
    {
      "id": "mapZoom",
      "label": "Map viewport",
      "type": "text",
      "group": "map",
      "default": "2.2511%2C-348.76%2C-147.81",
      "placeholder": "pan & zoom map to set",
      "help": "Auto-saved when you pan or zoom. Clear to reset to default view."
    },
    {
      "id": "pinColor",
      "label": "Pin color",
      "type": "color",
      "group": "map",
      "default": ""
    },
    {
      "id": "pinShape",
      "label": "Pin shape",
      "type": "select",
      "group": "map",
      "default": "circle",
      "options": [
        { "value": "circle",  "label": "Circle" },
        { "value": "diamond", "label": "Diamond" },
        { "value": "square",  "label": "Square" }
      ]
    },
    {
      "id": "pinSize",
      "label": "Pin size",
      "type": "number",
      "display": "slider",
      "group": "map",
      "default": 1,
      "min": 0.01,
      "max": 3,
      "step": 0.01
    },
    {
      "id": "labelSize",
      "label": "Label size",
      "type": "number",
      "display": "slider",
      "group": "map",
      "default": 1,
      "min": 0.01,
      "max": 4,
      "step": 0.01
    },
    {
      "id": "showNameInPin",
      "label": "Show name on pin",
      "type": "boolean",
      "group": "map",
      "default": false
    },
    {
      "id": "hideCity",
      "label": "Remove city from label",
      "type": "boolean",
      "group": "map",
      "default": false
    },
    {
      "id": "fontSize",
      "label": "Card text size",
      "type": "number",
      "display": "slider",
      "group": "map",
      "default": 1,
      "min": 0.7,
      "max": 1.5,
      "step": 0.05
    },
    {
      "id": "people",
      "label": "Team members",
      "type": "blocks",
      "fields": [
        { "id": "name", "label": "Name",  "placeholder": "Name" },
        { "id": "city", "label": "City",  "placeholder": "City" }
      ],
      "default": [
        {"name":"", "city":""}
      ]
    }
  ]
}
