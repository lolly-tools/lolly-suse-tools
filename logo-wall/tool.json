{
  "id": "logo-wall",
  "name": "Logo Lockup: Grid (NASCAR)",
  "description": "Arrange a pile of logos into a clean, even sponsor grid — the “NASCAR” wall.",
  "version": "1.1.0",
  "engineVersion": "^1.0.0",
  "status": "experimental",
  "category": "designer",
  "tags": ["logo", "lockup", "wall", "grid", "nascar", "logos", "brand", "partners", "customers", "sponsors", "clients", "montage", "cloud", "vector", "threshold", "on-device"],
  "a11yLabel": "A grid of {{logos.length}} logos",
  "examples": [
    { "label": "White · 4-up icons", "values": { "columns": 4, "gap": 36, "padding": 56, "background": "#ffffff", "balance": true, "logos": [ { "logo": "suse/icons/ai" }, { "logo": "suse/icons/boxes" }, { "logo": "suse/icons/brain" }, { "logo": "suse/icons/certificate" }, { "logo": "suse/icons/book" }, { "logo": "suse/icons/calendar" }, { "logo": "suse/icons/bug" }, { "logo": "suse/icons/box" } ] } },
    { "label": "Mint · 3-up airy", "values": { "columns": 3, "gap": 56, "padding": 80, "background": "#eafaf1", "balance": true, "logos": [ { "logo": "suse/icons/ai" }, { "logo": "suse/icons/boxes" }, { "logo": "suse/icons/brain" }, { "logo": "suse/icons/certificate" }, { "logo": "suse/icons/book" }, { "logo": "suse/icons/calendar" } ] } },
    { "label": "Pine · white ink", "values": { "columns": 4, "gap": 32, "padding": 48, "background": "#0c322c", "inkColor": "#ffffff", "balance": true, "logos": [ { "logo": "suse/icons/ai" }, { "logo": "suse/icons/boxes" }, { "logo": "suse/icons/brain" }, { "logo": "suse/icons/certificate" }, { "logo": "suse/icons/book" }, { "logo": "suse/icons/calendar" }, { "logo": "suse/icons/bug" }, { "logo": "suse/icons/box" } ] } },
    { "label": "Blue · white ink", "values": { "columns": 4, "gap": 40, "padding": 56, "background": "#0a9bd6", "inkColor": "#ffffff", "balance": true, "logos": [ { "logo": "suse/icons/ai" }, { "logo": "suse/icons/boxes" }, { "logo": "suse/icons/brain" }, { "logo": "suse/icons/certificate" }, { "logo": "suse/icons/book" }, { "logo": "suse/icons/calendar" }, { "logo": "suse/icons/bug" }, { "logo": "suse/icons/box" } ] } },
    { "label": "White · 6-up dense", "values": { "columns": 6, "gap": 20, "padding": 40, "background": "#ffffff", "balance": true, "logos": [ { "logo": "suse/icons/ai" }, { "logo": "suse/icons/boxes" }, { "logo": "suse/icons/brain" }, { "logo": "suse/icons/certificate" }, { "logo": "suse/icons/book" }, { "logo": "suse/icons/calendar" }, { "logo": "suse/icons/bug" }, { "logo": "suse/icons/box" }, { "logo": "suse/icons/boat" }, { "logo": "suse/icons/bike" }, { "logo": "suse/icons/canyon" }, { "logo": "suse/icons/automotive" } ] } },
    { "label": "Sky · 5-up cool", "values": { "columns": 5, "gap": 40, "padding": 56, "background": "#eef3ff", "inkColor": "#192072", "balance": true, "logos": [ { "logo": "suse/icons/cloud-computing" }, { "logo": "suse/icons/containers" }, { "logo": "suse/icons/database" }, { "logo": "suse/icons/edge" }, { "logo": "suse/icons/globe" }, { "logo": "suse/icons/growth" }, { "logo": "suse/icons/community" }, { "logo": "suse/icons/chart" }, { "logo": "suse/icons/energy" }, { "logo": "suse/icons/healthcare" } ] } },
    { "label": "Ember · 6-up on pine", "values": { "columns": 6, "gap": 24, "padding": 44, "background": "#0c322c", "inkColor": "#fe7c3f", "balance": true, "logos": [ { "logo": "suse/icons/ai" }, { "logo": "suse/icons/boxes" }, { "logo": "suse/icons/brain" }, { "logo": "suse/icons/cloud-computing" }, { "logo": "suse/icons/containers" }, { "logo": "suse/icons/database" }, { "logo": "suse/icons/edge" }, { "logo": "suse/icons/globe" }, { "logo": "suse/icons/growth" }, { "logo": "suse/icons/community" }, { "logo": "suse/icons/chart" }, { "logo": "suse/icons/energy" } ] } }
  ],
  "render": {
    "width": 1280,
    "height": 720,
    "formats": ["png", "svg", "pdf", "dxf", "jpg", "webp"],
    "actions": ["copy", "download", "save"],
    "layout": "sidebar",
    "transparentBg": true,
    "convertPaths": false
  },
  "hooks": {
    "onInit": true,
    "onInput": true,
    "beforeExport": true
  },
  "inputs": [
    {
      "id": "columns",
      "label": "Columns",
      "type": "number",
      "display": "slider",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4,
      "help": "How many logos sit in each row."
    },
    {
      "id": "gap",
      "label": "Spacing",
      "type": "number",
      "display": "slider",
      "min": 0,
      "max": 160,
      "step": 1,
      "default": 32,
      "help": "Gap between logos."
    },
    {
      "id": "padding",
      "label": "Padding",
      "type": "number",
      "display": "slider",
      "min": 0,
      "max": 200,
      "step": 1,
      "default": 48,
      "help": "Breathing room around the whole wall."
    },
    {
      "id": "background",
      "label": "Background",
      "type": "color",
      "default": "#ffffff"
    },
    {
      "id": "balance",
      "label": "Balance sizes",
      "type": "boolean",
      "default": true,
      "help": "Auto-size each logo by its optical weight — heavier logos shrink, lighter ones grow — so the wall reads as evenly weighted. Each logo's own Size % still applies on top. Turn off for uniform sizing."
    },
    {
      "id": "inkColor",
      "label": "Ink colour",
      "type": "color",
      "default": "#0c322c",
      "help": "The single ink for any logo set to “Render as vector” (per logo, below)."
    },
    {
      "id": "threshold",
      "label": "Vector threshold",
      "type": "number",
      "display": "slider",
      "min": 1,
      "max": 99,
      "step": 1,
      "default": 55,
      "help": "Default brightness cut-off for vector logos. Higher keeps more of each logo; tune a finnicky one per logo below."
    },
    {
      "id": "invert",
      "label": "Vector invert",
      "type": "boolean",
      "default": false,
      "help": "Default for vector logos — swap which side of the threshold becomes ink. White / pale logos are auto-inverted, so you rarely need this; tune per logo below if one needs it."
    },
    {
      "id": "detail",
      "label": "Vector detail",
      "type": "number",
      "display": "slider",
      "min": 80,
      "max": 600,
      "step": 10,
      "default": 300,
      "help": "Default tracing resolution for vector logos. Higher captures finer shapes but is heavier."
    },
    {
      "id": "smoothing",
      "label": "Vector smoothing",
      "type": "number",
      "display": "slider",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "help": "Default for vector logos: how much traced outlines round into curves. Low keeps edges crisp; high flows them into smooth Bézier curves."
    },
    {
      "id": "logos",
      "label": "Logos",
      "type": "blocks",
      "labelledFields": true,
      "dropToAdd": { "field": "logo", "accept": "image/*" },
      "fields": [
        { "id": "logo", "label": "Image", "type": "asset", "assetType": "any", "allowUpload": true },
        { "id": "presence", "label": "Presence", "type": "select", "default": "normal",
          "help": "How prominent this logo is. Balancing equalises everyone first; Presence then deliberately weights this one up or down — sponsor-tier sizing.",
          "options": [
            { "value": "hero", "label": "Hero" },
            { "value": "large", "label": "Large" },
            { "value": "normal", "label": "Normal" },
            { "value": "small", "label": "Small" }
          ] },
        { "id": "scale", "label": "Size %", "type": "number", "display": "slider", "min": 25, "max": 300, "step": 5, "default": 100, "help": "Fine nudge on top of Presence and balancing." },
        { "id": "opacity", "label": "Opacity", "type": "number", "display": "slider", "min": 0, "max": 1, "step": 0.05, "default": 1 },
        { "id": "filter", "label": "Filter", "type": "select", "default": "none", "options": [
          { "value": "none", "label": "None" },
          { "value": "grayscale", "label": "Grayscale" }
        ] },
        { "id": "vectorize", "label": "Render as vector", "type": "boolean", "default": false,
          "help": "Flatten this logo to the single ink colour (crisp vector). Off keeps it as its original image." },
        { "id": "tune", "label": "Tune this logo", "type": "boolean", "default": false, "showIf": { "vectorize": true },
          "help": "Give this logo its own vector settings — for finnicky marks that need a different threshold or inverting." },
        { "id": "threshold", "label": "Threshold", "type": "number", "display": "slider", "min": 1, "max": 99, "step": 1, "default": 55, "showIf": { "vectorize": true, "tune": true },
          "help": "Brightness cut-off for this logo. Higher keeps more of it." },
        { "id": "invert", "label": "Invert", "type": "boolean", "default": false, "showIf": { "vectorize": true, "tune": true },
          "help": "For a white or pale logo." },
        { "id": "detail", "label": "Detail", "type": "number", "display": "slider", "min": 80, "max": 320, "step": 10, "default": 200, "showIf": { "vectorize": true, "tune": true } },
        { "id": "smoothing", "label": "Smoothing", "type": "number", "display": "slider", "min": 0, "max": 100, "step": 5, "default": 60, "showIf": { "vectorize": true, "tune": true } }
      ],
      "default": []
    }
  ]
}
