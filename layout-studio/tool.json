{
  "id": "layout-studio",
  "name": "Layout Studio",
  "version": "1.4.0",
  "engineVersion": "^1.12.0",
  "status": "community",
  "category": "designer",
  "tags": ["canvas", "layout", "wysiwyg", "editor", "poster", "compose", "design", "free-form", "import", "figma", "penpot", "pdf", "ai", "illustrator", "idml", "indesign", "adobe"],
  "featured": {
    "order": 1,
    "blurb": "Free-form layouts on an open canvas"
  },
  "examples": [
    {"label":"Event promo · pine","values":{"background":"#0c322c","boxes":[{"id":"bg","kind":"box","x":0,"y":0,"w":1080,"h":1080,"rot":0,"shape":"rounded","bg":"#0c322c"},{"id":"accent","kind":"box","x":620,"y":-300,"w":760,"h":760,"rot":0,"shape":"ellipse","bg":"#30ba78"},{"id":"illo","kind":"image","x":560,"y":120,"w":480,"h":480,"rot":0,"shape":"rounded","radius":0,"bg":"transparent","opacity":100,"fit":"contain","image":{"source":"library","id":"suse/illustrations/cloud-native"}},{"id":"logo","kind":"image","x":89,"y":90,"w":300,"h":110,"rot":0,"shape":"rounded","radius":0,"bg":"transparent","opacity":100,"fit":"contain","image":{"source":"library","id":"suse/logo/hor-neg-white"}},{"id":"head","kind":"text","x":89,"y":640,"w":900,"h":200,"rot":0,"shape":"rect","text":"Cloud Native Summit {#30ba78|2026}","fg":"#ffffff","fontSize":76,"align":"left","valign":"top","weight":"600","font":"SUSE","lineHeight":1.1},{"id":"date","kind":"text","x":89,"y":880,"w":900,"h":70,"rot":0,"shape":"rect","text":"12 November 2026   ·   Berlin","fg":"#c0efde","fontSize":34,"align":"left","valign":"top","weight":"300","font":"SUSE","lineHeight":1.12}]}},
    {"label":"Quote card · mint","values":{"background":"#eafaf4","boxes":[{"id":"card","kind":"box","x":80,"y":80,"w":920,"h":920,"rot":0,"shape":"rounded","bg":"#ffffff","radius":32},{"id":"quote","kind":"text","x":150,"y":250,"w":780,"h":380,"rot":0,"shape":"rect","text":"“Open source is how the world builds what comes next.”","fg":"#0c322c","fontSize":58,"align":"left","valign":"top","weight":"500","font":"SUSE","lineHeight":1.15},{"id":"attr","kind":"text","x":150,"y":690,"w":780,"h":60,"rot":0,"shape":"rect","text":"SUSE — Open by design","fg":"#30ba78","fontSize":28,"align":"left","valign":"top","weight":"600","font":"SUSE","lineHeight":1.12},{"id":"logo","kind":"image","x":150,"y":850,"w":240,"h":84,"rot":0,"shape":"rounded","radius":0,"bg":"transparent","opacity":100,"fit":"contain","image":{"source":"library","id":"suse/logo/hor-pos-green"}}]}},
    {"label":"Product hero · split","values":{"background":"#ffffff","boxes":[{"id":"left","kind":"box","x":0,"y":0,"w":540,"h":1080,"rot":0,"shape":"rect","bg":"#192072"},{"id":"right","kind":"box","x":540,"y":0,"w":540,"h":1080,"rot":0,"shape":"rect","bg":"#eafaf4"},{"id":"head","kind":"text","x":72,"y":170,"w":410,"h":300,"rot":0,"shape":"rect","text":"Enterprise Linux, {#30ba78|reimagined}","fg":"#ffffff","fontSize":60,"align":"left","valign":"top","weight":"600","font":"SUSE","lineHeight":1.12},{"id":"body","kind":"text","x":72,"y":520,"w":410,"h":180,"rot":0,"shape":"rect","text":"One secure platform from edge to core.","fg":"#c0efde","fontSize":28,"align":"left","valign":"top","weight":"300","font":"SUSE","lineHeight":1.3},{"id":"cta","kind":"box","x":72,"y":770,"w":270,"h":84,"rot":0,"shape":"rounded","bg":"#fe7c3f","radius":42},{"id":"ctatext","kind":"text","x":72,"y":792,"w":270,"h":44,"rot":0,"shape":"rect","text":"Learn more →","fg":"#ffffff","fontSize":26,"align":"center","valign":"top","weight":"600","font":"SUSE","lineHeight":1.12},{"id":"illo","kind":"image","x":610,"y":320,"w":400,"h":400,"rot":0,"shape":"rounded","radius":0,"bg":"transparent","opacity":100,"fit":"contain","image":{"source":"library","id":"suse/illustrations/ai-enterprise"}}]}},
    {"label":"Announcement · jade band","values":{"background":"#ffffff","boxes":[{"id":"band","kind":"box","x":0,"y":0,"w":1080,"h":360,"rot":0,"shape":"rect","bg":"#30ba78"},{"id":"logo","kind":"image","x":89,"y":120,"w":300,"h":110,"rot":0,"shape":"rounded","radius":0,"bg":"transparent","opacity":100,"fit":"contain","image":{"source":"library","id":"suse/logo/hor-neg-white"}},{"id":"head","kind":"text","x":89,"y":460,"w":920,"h":280,"rot":0,"shape":"rect","text":"SUSE Linux Enterprise 16 {#30ba78|is here}","fg":"#0c322c","fontSize":68,"align":"left","valign":"top","weight":"600","font":"SUSE","lineHeight":1.12},{"id":"body","kind":"text","x":89,"y":770,"w":900,"h":120,"rot":0,"shape":"rect","text":"Generally available today across every major cloud.","fg":"#0c322c","fontSize":30,"align":"left","valign":"top","weight":"300","font":"SUSE","lineHeight":1.3}]}}
  ],
  "render": {
    "width": 1080,
    "height": 1080,
    "formats": ["png", "svg", "pdf", "jpg", "webp"],
    "actions": ["copy", "download", "save", "share"],
    "layout": "editor",
    "transparentBg": true,
    "printMarks": false
  },
  "hooks": { "onInit": true, "onInput": true, "beforeExport": true },
  "inputs": [
    {
      "id": "background",
      "type": "color",
      "label": "Canvas background",
      "default": "#ffffff"
    },
    {
      "id": "boxes",
      "type": "blocks",
      "label": "Boxes",
      "labelledFields": true,
      "addMenu": { "field": "kind", "label": "Add box" },
      "canvas": {
        "idField": "id",
        "xField": "x",
        "yField": "y",
        "wField": "w",
        "hField": "h",
        "rotationField": "rot",
        "shapeField": "shape",
        "radiusField": "radius",
        "fillField": "bg",
        "opacityField": "opacity",
        "imageField": "image",
        "imgPosField": "imgpos",
        "textField": "text",
        "textColorField": "fg",
        "fontSizeField": "fontSize",
        "alignField": "align",
        "valignField": "valign",
        "weightField": "weight",
        "fontField": "font",
        "lineHeightField": "lineHeight",
        "trackingField": "tracking",
        "ligaturesField": "ligatures",
        "alternatesField": "alternates",
        "padField": "pad",
        "fitField": "fit",
        "blendField": "blend",
        "groupField": "group",
        "clipField": "clip",
        "shadowField": "shadow",
        "shadowColorField": "shadowColor",
        "shadowXField": "shadowX",
        "shadowYField": "shadowY",
        "shadowBlurField": "shadowBlur",
        "minSize": 8,
        "import": { "formats": ["svg", "penpot", "pdf", "ai", "idml"] },
        "addKinds": [
          { "id": "box", "label": "Box", "seed": { "kind": "box", "bg": "#30BA78", "shape": "rounded", "text": "" } },
          { "id": "text", "label": "Text", "seed": { "kind": "text", "bg": "", "shape": "rect", "text": "Text", "fg": "#0c322c", "fontSize": 64, "valign": "top", "font": "SUSE", "lineHeight": 1.12 } },
          { "id": "image", "label": "Image", "seed": { "kind": "image", "bg": "#eef1f0", "shape": "rounded", "fit": "contain", "text": "" } },
          { "id": "lottie", "label": "Animation", "seed": { "kind": "image", "bg": "", "shape": "rounded", "fit": "contain", "text": "" } },
          { "id": "video", "label": "Video", "seed": { "kind": "image", "bg": "", "shape": "rounded", "fit": "contain", "text": "" } }
        ]
      },
      "fields": [
        { "id": "id", "type": "text" },
        {
          "id": "kind",
          "type": "select",
          "label": "Kind",
          "default": "box",
          "options": [
            { "value": "box", "label": "Box", "repeatable": true },
            { "value": "text", "label": "Text", "repeatable": true },
            { "value": "image", "label": "Image", "repeatable": true }
          ]
        },
        { "id": "x", "type": "number", "label": "X", "default": 120 },
        { "id": "y", "type": "number", "label": "Y", "default": 120 },
        { "id": "w", "type": "number", "label": "Width", "default": 320, "min": 1 },
        { "id": "h", "type": "number", "label": "Height", "default": 200, "min": 1 },
        { "id": "rot", "type": "number", "label": "Rotation", "default": 0, "min": -180, "max": 180 },
        {
          "id": "shape",
          "type": "select",
          "label": "Shape",
          "default": "rect",
          "options": [
            { "value": "rect", "label": "Rectangle" },
            { "value": "rounded", "label": "Rounded" },
            { "value": "pill", "label": "Pill" },
            { "value": "ellipse", "label": "Ellipse" }
          ]
        },
        { "id": "radius", "type": "number", "label": "Corner radius", "default": 16, "min": 0, "showIf": { "shape": "rounded" } },
        { "id": "bg", "type": "color", "label": "Fill", "default": "#30BA78" },
        { "id": "opacity", "type": "number", "label": "Opacity", "default": 100, "min": 0, "max": 100, "display": "slider" },
        { "id": "image", "type": "asset", "label": "Image, animation or video", "assetType": "any", "allowUpload": true, "help": "A photo, logo, SVG, GIF, Lottie animation, or a short video (MP4/WebM). Animations and video play live on the canvas; still exports (PNG/SVG/PDF) capture the current frame." },
        {
          "id": "fit",
          "type": "select",
          "label": "Image fit",
          "default": "contain",
          "options": [
            { "value": "contain", "label": "Contain (fit inside)" },
            { "value": "cover", "label": "Cover (crop to fill)" },
            { "value": "fill", "label": "Stretch" }
          ]
        },
        {
          "id": "blend",
          "type": "select",
          "label": "Blend mode",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "multiply", "label": "Multiply" },
            { "value": "screen", "label": "Screen" },
            { "value": "overlay", "label": "Overlay" },
            { "value": "darken", "label": "Darken" },
            { "value": "lighten", "label": "Lighten" },
            { "value": "color-dodge", "label": "Colour dodge" },
            { "value": "color-burn", "label": "Colour burn" },
            { "value": "hard-light", "label": "Hard light" },
            { "value": "soft-light", "label": "Soft light" },
            { "value": "difference", "label": "Difference" },
            { "value": "exclusion", "label": "Exclusion" },
            { "value": "hue", "label": "Hue" },
            { "value": "saturation", "label": "Saturation" },
            { "value": "color", "label": "Colour" },
            { "value": "luminosity", "label": "Luminosity" }
          ]
        },
        { "id": "text", "type": "text", "label": "Text", "default": "", "multilineFor": ["box", "text", "image"], "rows": 3, "help": "Rich text: **bold**, *italic* / _italic_, and lines starting with - or • become bullets." },
        { "id": "fg", "type": "color", "label": "Text colour", "default": "#0c322c" },
        { "id": "fontSize", "type": "number", "label": "Text size", "default": 48, "min": 4 },
        {
          "id": "align",
          "type": "select",
          "label": "Align",
          "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Centre" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "id": "valign",
          "type": "select",
          "label": "Vertical",
          "default": "middle",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "id": "weight",
          "type": "select",
          "label": "Weight",
          "default": "500",
          "help": "Black (900) is SUSE Sans only — SUSE Mono tops out at Extrabold (800).",
          "options": [
            { "value": "100", "label": "Thin" },
            { "value": "200", "label": "Extra light" },
            { "value": "300", "label": "Light" },
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semibold" },
            { "value": "700", "label": "Bold" },
            { "value": "800", "label": "Extrabold" },
            { "value": "900", "label": "Black" }
          ]
        },
        {
          "id": "font",
          "type": "select",
          "label": "Font",
          "default": "SUSE",
          "options": [
            { "value": "SUSE", "label": "SUSE Sans" },
            { "value": "SUSE Mono", "label": "SUSE Mono" }
          ]
        },
        { "id": "lineHeight", "type": "number", "label": "Line height", "default": 1.12, "min": 0.7, "max": 3, "step": 0.05 },
        { "id": "tracking", "type": "number", "label": "Kerning", "default": 0, "min": -100, "max": 400, "step": 0.5, "help": "Uniform letter spacing (tracking) in px. Baked into the vector export." },
        { "id": "ligatures", "type": "boolean", "label": "Ligatures", "default": true, "help": "Standard ligatures (fi, fl, …). Applies on screen and in the outlined SVG/PDF/EMF export." },
        { "id": "alternates", "type": "boolean", "label": "Stylistic alternates", "default": false, "help": "OpenType stylistic alternates (salt), where the font provides them." },
        { "id": "group", "type": "text", "label": "Group", "default": "" },
        { "id": "clip", "type": "text", "label": "Clip to", "default": "" },
        { "id": "pad", "type": "number", "label": "Text padding", "default": 8, "min": 0 },
        {
          "id": "shadow",
          "type": "select",
          "label": "Shadow",
          "default": "none",
          "help": "What the drop shadow applies to: the box outline, the text, or the visible content (image alpha). Raster export only — SVG/PDF flatten it.",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "box", "label": "Box" },
            { "value": "text", "label": "Text" },
            { "value": "content", "label": "Content" }
          ]
        },
        { "id": "shadowColor", "type": "color", "label": "Shadow colour", "default": "#00000055" },
        { "id": "shadowX", "type": "number", "label": "Shadow X", "default": 0, "min": -300, "max": 300 },
        { "id": "shadowY", "type": "number", "label": "Shadow Y", "default": 0, "min": -300, "max": 300 },
        { "id": "shadowBlur", "type": "number", "label": "Shadow blur", "default": 10, "min": 0, "max": 300 },
        {
          "id": "imgpos",
          "type": "select",
          "label": "Image position",
          "default": "center",
          "help": "Which edge or corner the image is anchored to — where a contained image sits inside the box, or which part of a cover-cropped image stays in frame. Honoured on screen and in PNG/SVG/PDF export.",
          "options": [
            { "value": "left top", "label": "Top left" },
            { "value": "center top", "label": "Top" },
            { "value": "right top", "label": "Top right" },
            { "value": "left center", "label": "Left" },
            { "value": "center", "label": "Centre" },
            { "value": "right center", "label": "Right" },
            { "value": "left bottom", "label": "Bottom left" },
            { "value": "center bottom", "label": "Bottom" },
            { "value": "right bottom", "label": "Bottom right" }
          ]
        }
      ],
      "default": [
        { "id": "byq0l1tji", "kind": "box", "x": 0, "y": 0, "w": 1080, "h": 1080, "rot": 0, "shape": "rounded", "bg": "#0c322c" },
        { "id": "logo", "kind": "image", "x": 89, "y": 476, "w": 311, "h": 192, "rot": 0, "shape": "rounded", "radius": 0, "bg": "transparent", "opacity": 100, "fit": "contain", "image": { "source": "remote", "id": "https://lolly.tools/tool/brand-lockup.svg?name=Studio&category=event&location=Noosa&orientation=stacked&polarity=negative&treatment=colour&wrapMode=compact&size=fit&background=transparent&convertPaths=1&w=900&h=400", "_unresolved": true } },
        { "id": "bwiec0em2", "kind": "box", "x": 585, "y": -325, "w": 842, "h": 842, "rot": 0, "shape": "ellipse", "bg": "#c0efde" },
        { "id": "geeko", "kind": "image", "x": 399, "y": -267, "w": 681, "h": 1104, "rot": 0, "shape": "rounded", "radius": 0, "bg": "transparent", "opacity": 100, "fit": "contain", "image": { "source": "remote", "id": "https://lolly.tools/tool/pose-geeko.svg?pose=curious&eyeX=1&eyeY=105&blink=0&headTilt=5&foliage=0&legFront=0&legBack=0&tail=0&geeko.scale=1&geeko.x=0&geeko.y=0&flip=0&bg=transparent&convertPaths=1&w=800&h=800", "_unresolved": true } },
        { "id": "b35it2zk", "kind": "text", "x": 89, "y": 855, "w": 916, "h": 99, "rot": 0, "shape": "rect", "text": "17th July 2026     |     6:00 PM onwards", "fg": "#c0efde", "fontSize": 34, "align": "left", "valign": "top", "weight": "300", "font": "SUSE", "lineHeight": 1.12 },
        { "id": "bn1vt0irb", "kind": "text", "x": 89, "y": 637, "w": 909, "h": 183, "rot": 0, "shape": "rect", "text": "Modernizing Infrastructure \nfor the Cloud-Native {#ffffff|Era}", "fg": "#ffffff", "fontSize": 70, "align": "left", "valign": "top", "weight": "500", "font": "SUSE", "lineHeight": 1.12, "group": "text" }
      ]
    }
  ]
}
