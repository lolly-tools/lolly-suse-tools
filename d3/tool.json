      "type": "select",
      "default": "uniform",
      "options": [
        {
          "value": "uniform",
          "label": "Uniform dots"
        },
        {
          "value": "auto",
          "label": "By 3rd number column (bubble)"
        }
      ],
      "showIf": {
        "chartType": "scatter"
      }
    },
    {
      "id": "lineWidth",
      "urlKey": "lw",
      "label": "Line width",
      "section": "Chart",
      "type": "number",
      "display": "slider",
      "default": 3,
      "min": 1,
      "max": 16,
      "step": 1,
      "showIf": {
        "chartType": [
          "line",
          "area",
          "radar",
