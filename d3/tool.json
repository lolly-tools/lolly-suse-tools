          "label": "Streamgraph"
        },
        {
          "value": "waterfall",
          "label": "Waterfall"
        },
        {
          "value": "marimekko",
          "label": "Marimekko / mekko"
        },
        {
          "value": "parallel",
          "label": "Parallel coordinates"
        },
        {
          "value": "polar",
          "label": "Polar area / rose"
