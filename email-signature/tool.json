{
  "id": "email-signature",
  "name": "Email Signature",
  "description": "An on-brand SUSE email signature, ready to paste into any client.",
  "version": "1.3.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "everyone",
  "tags": ["email", "signature", "contact", "branding"],
  "examples": [
    { "label": "Engineer · Germany append", "values": { "logo": "standard", "firstname": "Amina", "lastname": "Okafor", "jobTitle": "Principal Engineer, Rancher", "email": "amina.okafor@suse.com", "phone": "+49 911 740530", "mobile": "+49 170 1234567", "im": "@amina on Slack", "append": "germany" } },
    { "label": "Sales · grey logo · business", "values": { "logo": "grey", "firstname": "Diego", "lastname": "Fernández", "jobTitle": "Account Executive, EMEA", "email": "diego.fernandez@suse.com", "phone": "+34 91 123 4567", "mobile": "+34 600 123 456", "address": "Calle de Alcalá 42", "address2": "28014 Madrid, Spain", "append": "business" } },
    { "label": "Support · certifications", "values": { "logo": "standard", "firstname": "Mei", "lastname": "Chen", "jobTitle": "Technical Support Engineer", "certs": "SCA, RHCE, CKA", "email": "mei.chen@suse.com", "phone": "+65 6800 1234", "im": "@mei", "append": "none" } },
    { "label": "Marketing · wellbeing", "values": { "logo": "standard", "firstname": "Sofia", "lastname": "Rossi", "jobTitle": "Marketing Manager, Cloud Native", "email": "sofia.rossi@suse.com", "mobile": "+39 340 123 4567", "append": "wellbeing" } },
    { "label": "Executive · grey logo", "values": { "logo": "grey", "firstname": "Sam", "lastname": "Whitfield", "jobTitle": "VP of Engineering", "email": "sam.whitfield@suse.com", "phone": "+1 415 555 0142", "mobile": "+1 415 555 0199", "address": "1 Innovation Way", "address2": "Provo, UT 84604", "append": "business" } },
    { "label": "Developer advocate", "values": { "logo": "standard", "firstname": "Ravi", "lastname": "Patel", "jobTitle": "Developer Advocate, Kubernetes", "email": "ravi.patel@suse.com", "mobile": "+91 98765 43210", "im": "@ravi on Slack", "append": "none" } }
  ],
  "render": {
    "width": 600,
    "height": 300,
    "formats": ["html", "txt", "png", "svg", "vcf", "json"],
    "actions": ["copy", "download", "save"]
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "logo",
      "label": "Logo",
      "type": "select",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "grey",     "label": "Grey" }
      ],
      "help": "Select Grey if you think most of your audience prefers dark mode"
    },
    {
      "id": "headshot",
      "label": "Headshot",
      "type": "asset",
      "assetType": "raster",
      "allowUpload": true,
      "filter": { "namespace": "suse/headshots" },
      "help": "Optional headshot. Displayed as a circle."
    },
    {
      "id": "emailPromo",
      "label": "Email Promo",
      "type": "asset",
      "assetType": "raster",
      "allowUpload": true,
      "help": "Optional promo banner below the signature. Scaled to fit within 400×200px, aspect preserved."
    },
    {
      "id": "firstname",
      "label": "First Name",
      "type": "text",
      "required": true,
      "default": "",
      "bindToProfile": "firstname"
    },
    {
      "id": "lastname",
      "label": "Last Name",
      "type": "text",
      "default": "",
      "bindToProfile": "lastname"
    },
    {
      "id": "nameWeight",
      "label": "Name weight",
      "type": "number",
      "display": "slider",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 500,
      "help": "Font weight of your name (100 Thin → 900 Black)."
    },
    {
      "id": "jobTitle",
      "label": "Job Title, Department",
      "type": "text",
      "default": "",
      "placeholder": "Senior Engineer, Product"
    },
    {
      "id": "titleWeight",
      "label": "Title weight",
      "type": "number",
      "display": "slider",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 400,
      "help": "Font weight of the job title line (100 Thin → 900 Black)."
    },
    {
      "id": "certs",
      "label": "Certifications",
      "type": "text",
      "default": "",
      "placeholder": ""
    },
    {
      "id": "email",
      "label": "Email",
      "type": "text",
      "default": "",
      "bindToProfile": "email"
    },
    {
      "id": "phone",
      "label": "Desk Phone",
      "type": "text",
      "default": "",
      "bindToProfile": "phone"
    },
    {
      "id": "mobile",
      "label": "Mobile",
      "type": "text",
      "default": ""
    },
    {
      "id": "fax",
      "label": "Fax",
      "type": "text",
      "default": ""
    },
    {
      "id": "address",
      "label": "Address",
      "type": "text",
      "default": ""
    },
    {
      "id": "address2",
      "label": "Address Line 2",
      "type": "text",
      "default": ""
    },
    {
      "id": "im",
      "label": "IM Handle",
      "type": "text",
      "default": "",
      "placeholder": "@handle on Slack"
    },
    {
      "id": "append",
      "label": "Append",
      "type": "select",
      "default": "none",
      "options": [
        { "value": "none",    "label": "None" },
        { "value": "germany", "label": "Germany" },
        { "value": "business","label": "Business" },
        { "value": "wellbeing", "label": "Wellbeing" }
      ]
    }
  ]
}
