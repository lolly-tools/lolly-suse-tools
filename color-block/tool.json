          { "kind": "body", "text": "Three days of open source, cloud native and AI.", "bgColor": "#0c322c", "fgColor": "#ffffff", "scale": 1, "weight": 400 },
          { "kind": "blank", "bgColor": "#192072", "bgImage": { "source": "library", "id": "suse/photos/susecon26-keynote-tues-95" } },
          { "kind": "logo", "logoOrient": "stacked", "logoColor": "green", "bgColor": "#bff1ea", "logoSize": 0.7 }
        ]
      }
