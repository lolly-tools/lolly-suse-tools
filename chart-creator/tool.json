{
  "id": "chart-creator",
  "name": "Chart Creator",
  "description": "On-brand charts from your data — bar, donut, pie or stacked.",
  "version": "1.0.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "designer",
  "tags": ["chart", "data", "visualization", "bar", "pie", "donut", "infographic", "svg"],
  "featured": {
    "order": 5,
    "blurb": "On-brand charts from your data, any shape"
  },
  "examples": [
    {
      "label": "Dark vertical bars",
      "values": {
        "chartType": "vertical-bar",
        "heading": "Clusters by distribution",
        "subheading": "RKE2, K3s and Harvester — illustrative sample data",
        "transparentBg": false,
        "background": "#0c322c",
        "color": "#ffffff",
        "data": [
          { "label": "RKE2",      "value": "64", "color": "#3c8eef" },
          { "label": "K3s",       "value": "48", "color": "#fe7c3f" },
          { "label": "Harvester", "value": "30", "color": "#42d29f" },
          { "label": "Hosted",    "value": "22", "color": "#fcb244" }
        ]
      }
    },
    {
      "label": "Horizontal bars",
      "values": {
        "chartType": "horizontal-bar",
        "heading": "Adoption across the SUSE stack",
        "subheading": "Deployments by product — illustrative sample data",
        "transparentBg": false,
        "background": "#ffffff",
        "color": "#0c322c",
        "labelSize": 34,
        "labelPosition": "inside",
        "labelAlign": "center",
        "valueSize": 34,
        "valuePosition": "outside",
        "valueAlign": "center",
        "data": [
          { "label": "SLES 16",       "value": "92", "color": "#0c322c" },
          { "label": "Rancher Prime", "value": "76", "color": "#17513f" },
          { "label": "SUSE Edge",     "value": "54", "color": "#008657" },
          { "label": "Harvester HCI", "value": "41", "color": "#30ba78" },
          { "label": "SUSE Security", "value": "33", "color": "#4fc48f" }
        ]
      }
    },
    {
      "label": "Pie with legend",
      "values": {
        "chartType": "pie",
        "heading": "Edge fleet by site type",
        "subheading": "Share of SUSE Edge nodes — illustrative sample data",
        "transparentBg": false,
        "background": "#0c322c",
        "color": "#ffffff",
        "showLegend": true,
        "legendPosition": "right",
        "legendDotShape": "circle",
        "data": [
          { "label": "Retail",        "value": "34", "color": "#3c8eef" },
          { "label": "Manufacturing", "value": "27", "color": "#fe7c3f" },
          { "label": "Telco / RAN",   "value": "21", "color": "#42d29f" },
          { "label": "Branch",        "value": "11", "color": "#fcb244" },
          { "label": "Logistics",     "value": "7",  "color": "#90ebcd" }
        ]
      }
    },
    {
      "label": "Stacked composite",
      "values": {
        "chartType": "stacked",
        "heading": "GPU hours across the AI pipeline",
        "subheading": "One AI Factory cluster, per month — illustrative sample data",
        "transparentBg": false,
        "background": "#ffffff",
        "color": "#0c322c",
        "showLegend": true,
        "data": [
          { "label": "Inference",   "value": "4600", "color": "#0c322c" },
          { "label": "Training",    "value": "2800", "color": "#17513f" },
          { "label": "Fine-tuning", "value": "1600", "color": "#008657" },
          { "label": "Retrieval",   "value": "900",  "color": "#30ba78" }
        ]
      }
    },
    {
      "label": "Donut with legend",
      "values": {
        "chartType": "donut",
        "heading": "Open source contributions",
        "subheading": "By SUSE project — illustrative sample data",
        "transparentBg": false,
        "background": "#ffffff",
        "color": "#0c322c",
        "donutRadius": 0.5,
        "showLegend": true,
        "legendPosition": "right",
        "legendDotShape": "circle",
        "data": [
          { "label": "Rancher",   "value": "42", "color": "#30ba78" },
          { "label": "K3s",       "value": "26", "color": "#0a9bd6" },
          { "label": "Longhorn",  "value": "18", "color": "#fcb244" },
          { "label": "NeuVector", "value": "14", "color": "#fe7c3f" }
        ]
      }
    },
    {
      "label": "Bright verticals",
      "values": {
        "chartType": "vertical-bar",
        "heading": "Community growth by region",
        "subheading": "New contributors this year — illustrative sample data",
        "transparentBg": false,
        "background": "#ffffff",
        "color": "#0c322c",
        "data": [
          { "label": "EMEA",     "value": "58", "color": "#30ba78" },
          { "label": "Americas", "value": "46", "color": "#0a9bd6" },
          { "label": "APAC",     "value": "39", "color": "#fcb244" },
          { "label": "Global",   "value": "24", "color": "#fe7c3f" }
        ]
      }
    }
  ],
  "render": {
    "width": 1080,
    "height": 1080,
    "formats": ["png", "svg", "emf", "pdf",  "pdf-cmyk", "cmyk-tiff", "tiff", "pptx", "webp", "csv", "md"],
    "actions": ["copy", "download", "save"],
    "transparentBg": true
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "chartType", "urlKey": "ct",
      "label": "Chart type",
      "type": "select",
      "default": "donut",
      "options": [
        { "value": "vertical-bar",   "label": "Vertical bars" },
        { "value": "horizontal-bar", "label": "Horizontal bars" },
        { "value": "donut",          "label": "Donut" },
        { "value": "pie",            "label": "Pie" },
        { "value": "stacked",        "label": "Stacked bar" }
      ]
    },
    {
      "id": "donutRadius", "urlKey": "dr",
      "label": "Donut radius",
      "type": "number",
      "display": "slider",
      "min": 0.10,
      "max": 0.90,
      "step": 0.01,
      "default": 0.44,
      "showIf": { "chartType": "donut" }
    },
    {
      "id": "stackMax", "urlKey": "sm",
      "label": "Scale max",
      "type": "number",
      "default": 0,
      "min": 0,
      "placeholder": "0 = fit to total",
      "help": "Leave 0 to fit the bar to your values’ total (a composite). Set a number to scale the composite against a fixed maximum — the bar fills that share and leaves an empty remainder.",
      "showIf": { "chartType": "stacked" }
    },
    {
      "id": "sliceGap", "urlKey": "sg",
      "label": "Gap between slices",
      "section": "Slices",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 40,
      "step": 1,
      "showIf": { "chartType": ["pie", "donut"] },
      "help": "Spacing between slices, in pixels at the outer edge. 0 = slices touch."
    },
    {
      "id": "cornerRadius", "urlKey": "cr",
      "label": "Corner radius",
      "section": "Slices",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 60,
      "step": 1,
      "showIf": { "chartType": ["pie", "donut"] },
      "help": "Rounds the corners of each slice. Clamped automatically for thin or narrow slices."
    },
    {
      "id": "strokeWidth", "urlKey": "ow",
      "label": "Outline width",
      "section": "Slices",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 24,
      "step": 1,
      "showIf": { "chartType": ["pie", "donut"] },
      "help": "Outline around each slice. 0 = no outline."
    },
    {
      "id": "strokeColor", "urlKey": "oc",
      "label": "Outline color",
      "section": "Slices",
      "type": "color",
      "default": "#ffffff",
      "showIf": { "chartType": ["pie", "donut"] }
    },
    {
      "id": "heading", "urlKey": "t",
      "label": "Title",
      "type": "text",
      "default": "",
      "placeholder": "Chart title"
    },
    {
      "id": "subheading", "urlKey": "st",
      "label": "Subtitle / source",
      "type": "text",
      "default": "",
      "placeholder": "Optional subtitle or data source"
    },
    {
      "id": "color", "urlKey": "tc",
      "label": "Text color",
      "type": "color",
      "default": "#0c322c"
    },
    {
      "id": "background", "urlKey": "bg",
      "label": "Background",
      "type": "color",
      "default": "#ffffff"
    },
    {
      "id": "showLegend", "urlKey": "lg",
      "label": "Show legend",
      "section": "Legend",
      "type": "boolean",
      "default": false
    },
    {
      "id": "legendPosition", "urlKey": "lp",
      "label": "Position",
      "section": "Legend",
      "type": "select",
      "default": "bottom",
      "options": [
        { "value": "bottom", "label": "Bottom" },
        { "value": "top", "label": "Top" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "showIf": { "showLegend": true }
    },
    {
      "id": "legendDotShape", "urlKey": "ld",
      "label": "Dot shape",
      "section": "Legend",
      "type": "select",
      "default": "circle",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "circle", "label": "Circle" }
      ],
      "showIf": { "showLegend": true }
    },
    {
      "id": "legendSize", "urlKey": "ls",
      "label": "Text size",
      "section": "Legend",
      "type": "number",
      "display": "slider",
      "default": 22,
      "min": 8,
      "max": 48,
      "step": 1,
      "showIf": { "showLegend": true }
    },
    {
      "id": "legendFontWeight", "urlKey": "lf",
      "label": "Font weight",
      "section": "Legend",
      "type": "number",
      "display": "slider",
      "default": 500,
      "min": 100,
      "max": 900,
      "step": 100,
      "showIf": { "showLegend": true }
    },
    {
      "id": "legendMaxChars", "urlKey": "lm",
      "label": "Max label length",
      "section": "Legend",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 60,
      "step": 1,
      "showIf": { "showLegend": true },
      "help": "Characters shown before a legend label is shortened with “…”. 0 = automatic."
    },
    {
      "id": "legendWidth", "urlKey": "lw",
      "label": "Legend width %",
      "section": "Legend",
      "type": "number",
      "display": "slider",
      "default": 40,
      "min": 15,
      "max": 65,
      "step": 1,
      "showIf": { "showLegend": true }
    },
    {
      "id": "showLabels", "urlKey": "sl",
      "label": "Show labels",
      "section": "Labels",
      "type": "boolean",
      "default": true
    },
    {
      "id": "labelSize", "urlKey": "lbs",
      "label": "Text size",
      "section": "Labels",
      "type": "number",
      "display": "slider",
      "default": 44,
      "min": 10,
      "max": 48,
      "step": 1
    },
    {
      "id": "labelWeight", "urlKey": "lbw",
      "label": "Font weight",
      "section": "Labels",
      "type": "number",
      "display": "slider",
      "default": 600,
      "min": 100,
      "max": 900,
      "step": 100
    },
    {
      "id": "labelMaxChars", "urlKey": "lbm",
      "label": "Max label length",
      "section": "Labels",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 60,
      "step": 1,
      "help": "Characters shown before a label is shortened with “…”. 0 = automatic."
    },
    {
      "id": "labelPosition", "urlKey": "lbp",
      "label": "Position",
      "section": "Labels",
      "type": "select",
      "default": "inside",
      "options": [
        { "value": "inside",  "label": "Inside" },
        { "value": "outside", "label": "Outside" }
      ]
    },
    {
      "id": "labelAlign", "urlKey": "lba",
      "label": "Align",
      "section": "Labels",
      "type": "select",
      "default": "bottom",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "id": "labelOffset",
      "label": "Offset",
      "section": "Labels",
      "type": "vector",
      "fields": [
        { "id": "x", "label": "X", "min": -100, "max": 100, "step": 1, "default": 0 },
        { "id": "y", "label": "Y", "min": -100, "max": 100, "step": 1, "default": 0 }
      ]
    },
    {
      "id": "labelGap", "urlKey": "lbg",
      "label": "Outside gap",
      "section": "Labels",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 120,
      "step": 1
    },
    {
      "id": "dataLabels", "urlKey": "dv",
      "label": "Show values",
      "section": "Value",
      "type": "boolean",
      "default": true
    },
    {
      "id": "valueSize", "urlKey": "vs",
      "label": "Text size",
      "section": "Value",
      "type": "number",
      "display": "slider",
      "default": 51,
      "min": 8,
      "max": 96,
      "step": 1
    },
    {
      "id": "valueWeight", "urlKey": "vw",
      "label": "Font weight",
      "section": "Value",
      "type": "number",
      "display": "slider",
      "default": 500,
      "min": 100,
      "max": 900,
      "step": 100
    },
    {
      "id": "valuePosition", "urlKey": "vp",
      "label": "Position",
      "section": "Value",
      "type": "select",
      "default": "inside",
      "options": [
        { "value": "inside",  "label": "Inside" },
        { "value": "outside", "label": "Outside" }
      ]
    },
    {
      "id": "valueAlign", "urlKey": "va",
      "label": "Align",
      "section": "Value",
      "type": "select",
      "default": "center",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "id": "valueOffset",
      "label": "Offset",
      "section": "Value",
      "type": "vector",
      "fields": [
        { "id": "x", "label": "X", "min": -100, "max": 100, "step": 1, "default": 0 },
        { "id": "y", "label": "Y", "min": -100, "max": 100, "step": 1, "default": 0 }
      ]
    },
    {
      "id": "valueGap", "urlKey": "vg",
      "label": "Outside gap",
      "section": "Value",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 120,
      "step": 1
    },
    {
      "id": "valueFormat", "urlKey": "vf",
      "label": "Number format",
      "section": "Value",
      "type": "select",
      "default": "auto",
      "options": [
        { "value": "auto",    "label": "Auto" },
        { "value": "value",   "label": "Original number" },
        { "value": "percent", "label": "Percentage" }
      ]
    },
    {
      "id": "data", "urlKey": "d",
      "label": "Data",
      "type": "blocks",
      "importData": { "formats": ["csv", "json"] },
      "fields": [
        { "id": "label", "urlKey": "l", "label": "Label", "placeholder": "Label" },
        { "id": "value", "urlKey": "v", "label": "Value", "placeholder": "0" },
        { "id": "color", "urlKey": "c", "label": "Color", "type": "color", "placeholder": "#30ba78" }
      ],
      "default": [
        { "label": "Public cloud", "value": "38", "color": "#008657" },
        { "label": "Data center",  "value": "31", "color": "#2453ff" },
        { "label": "Edge sites",   "value": "19", "color": "#fe7c3f" },
        { "label": "Air-gapped",   "value": "12", "color": "#00bda7" }
      ]
    },
    { "id": "width",  "label": "Width",  "type": "number", "default": 1080, "min": 100, "max": 8000, "group": "export" },
    { "id": "height", "label": "Height", "type": "number", "default": 1080, "min": 100, "max": 8000, "group": "export" }
  ]
}
