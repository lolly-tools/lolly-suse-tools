            { "value": "arc-flip", "label": "Arc — reverse bow" },
            { "value": "arc-flip-wide", "label": "Arc — wide reverse" }
          ]
        },
        {
          "id": "arrow",
          "type": "select",
          "label": "Arrowhead",
          "default": "end",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "end", "label": "At the end" },
            { "value": "both", "label": "Both ends" }
