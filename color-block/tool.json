    {
      "label": "Secure edge · tall · 5 blocks",
      "values": {
        "width": 1080, "height": 1920,
        "blocks": [
          { "kind": "logo", "logoOrient": "horizontal", "logoColor": "green", "bgColor": "#ffffff", "logoSize": 0.8 },
          { "kind": "heading", "text": "Secure by default", "bgColor": "#bff1ea", "fgColor": "#0c322c", "scale": 1.1, "weight": 800 },
