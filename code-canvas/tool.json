{
  "id": "code-canvas",
  "name": "Code Canvas",
  "description": "Turn code snippets into clean, syntax-highlighted, shareable images.",
  "version": "1.0.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "everyone",
  "tags": ["code", "developer", "snippet", "export"],
  "examples": [
    {
      "label": "JavaScript · SUSE Dark",
      "values": {
        "code": "const greet = (name) => {\n  console.log(`Hello, ${name}!`);\n  return name;\n};\n\ngreet('SUSE');",
        "filename": "app.js",
        "language": "javascript",
        "theme": "suse-dark",
        "windowStyle": "nuremberg",
        "lineNumbers": true
      }
    },
    {
      "label": "Python · GitHub Dark",
      "values": {
        "code": "def fib(n):\n    a, b = 0, 1\n    for _ in range(n):\n        a, b = b, a + b\n    return a\n\nprint(fib(12))",
        "filename": "fib.py",
        "language": "python",
        "theme": "github-dark",
        "windowStyle": "cupertino",
        "lineNumbers": true
      }
    },
    {
      "label": "Bash · Nord",
      "values": {
        "code": "#!/usr/bin/env bash\nset -euo pipefail\n\nfor host in web db cache; do\n  echo \"Deploying to $host…\"\n  ssh \"$host\" 'systemctl restart lolly'\ndone",
        "filename": "deploy.sh",
        "language": "bash",
        "theme": "nord",
        "windowStyle": "redmond",
        "lineNumbers": false
      }
    },
    {
      "label": "Go · GitHub Dark",
      "values": {
        "code": "package main\n\nimport \"fmt\"\n\nfunc main() {\n\tfor i := 0; i < 3; i++ {\n\t\tfmt.Println(\"Hello, SUSE!\")\n\t}\n}",
        "filename": "main.go",
        "language": "go",
        "theme": "github-dark",
        "windowStyle": "nuremberg",
        "lineNumbers": true
      }
    },
    {
      "label": "Rust · Nord",
      "values": {
        "code": "fn main() {\n    let name = \"SUSE\";\n    for _ in 0..3 {\n        println!(\"Hello, {name}!\");\n    }\n}",
        "filename": "lib.rs",
        "language": "rust",
        "theme": "nord",
        "windowStyle": "cupertino",
        "lineNumbers": true
      }
    },
    {
      "label": "TypeScript · SUSE Light",
      "values": {
        "code": "type User = { id: number; name: string };\n\nconst getUser = async (id: number): Promise<User> => {\n  const res = await fetch(`/api/users/${id}`);\n  return res.json();\n};",
        "filename": "api.ts",
        "language": "typescript",
        "theme": "suse-light",
        "windowStyle": "redmond",
        "lineNumbers": true
      }
    }
  ],
  "render": {
    "width": 1200,
    "height": 800,
    "formats": ["png", "svg"],
    "actions": ["copy", "download", "save"],
    "transparentBg": false
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "code",
      "label": "Code",
      "type": "longtext",
      "default": "const greet = (name) => {\n  console.log(`Hello, ${name}!`);\n  return name;\n};\n\ngreet('World');",
      "placeholder": "Paste your code here…"
    },
    {
      "id": "filename",
      "label": "Filename",
      "type": "text",
      "default": "",
      "placeholder": "snippet.js"
    },
    {
      "id": "language",
      "label": "Language",
      "type": "select",
      "default": "javascript",
      "options": [
        { "value": "auto",       "label": "Auto Detect" },
        { "value": "javascript", "label": "JavaScript" },
        { "value": "typescript", "label": "TypeScript" },
        { "value": "python",     "label": "Python" },
        { "value": "rust",       "label": "Rust" },
        { "value": "go",         "label": "Go" },
        { "value": "css",        "label": "CSS" },
        { "value": "html",       "label": "HTML" },
        { "value": "bash",       "label": "Bash / Shell" },
        { "value": "json",       "label": "JSON" },
        { "value": "plain",      "label": "Plain Text" }
      ]
    },
    {
      "id": "theme",
      "label": "Theme",
      "type": "select",
      "default": "suse-dark",
      "options": [
        { "value": "suse-dark",   "label": "SUSE Dark" },
        { "value": "suse-light",  "label": "SUSE Light" },
        { "value": "github-dark", "label": "GitHub Dark" },
        { "value": "nord",        "label": "Nord" }
      ]
    },
    {
      "id": "windowStyle",
      "label": "Window Manager",
      "type": "select",
      "default": "nuremberg",
      "help": "Window chrome look. Nuremberg = GNOME Adwaita, Cupertino = macOS, Redmond = Windows.",
      "options": [
        { "value": "cupertino", "label": "Cupertino" },
        { "value": "redmond",   "label": "Redmond" },
        { "value": "nuremberg", "label": "Nuremberg" }
      ]
    },
    {
      "id": "lineNumbers",
      "label": "Line Numbers",
      "type": "boolean",
      "default": true
    },
    {
      "id": "showWindow",
      "label": "Window Chrome",
      "type": "boolean",
      "default": true
    },
    {
      "id": "blinkCursor",
      "label": "Blink cursor",
      "help": "A terminal-style blinking caret after the code, on screen. Off keeps the exported still clean.",
      "type": "boolean",
      "default": false
    },
    {
      "id": "scale",
      "label": "Size",
      "type": "number",
      "display": "slider",
      "default": 100,
      "min": 70,
      "max": 200,
      "step": 5
    }
  ]
}
