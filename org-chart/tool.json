{
  "id": "org-chart",
  "name": "Flow Chart",
  "description": "Build flow charts on an open canvas — drag cards, connect them, and the lines route and stick to the boxes.",
  "version": "1.0.0",
  "engineVersion": "^1.12.0",
  "status": "community",
  "category": "everyone",
  "tags": ["flow chart", "flowchart", "flow", "diagram", "org chart", "org-chart", "orgchart", "hierarchy", "team", "people", "connectors", "canvas", "editor", "process", "structure", "nodes", "wysiwyg"],
  "featured": {
    "order": 5,
    "blurb": "Cards + connectors that stick to the boxes"
  },
  "examples": [
    {
      "label": "Leadership · light",
      "values": {
        "background": "#f4f7f6",
        "boxes": [
          { "id": "ceo", "kind": "card", "layout": "row", "x": 650, "y": 90, "w": 300, "h": 116, "rot": 0, "shape": "rounded", "radius": 18, "bg": "#0c322c", "accent": "#30ba78", "fit": "cover", "text": "Alex Rivera\n{w200|Chief Executive}", "fg": "#ffffff", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 },
          { "id": "cto", "kind": "card", "layout": "row", "x": 360, "y": 430, "w": 300, "h": 116, "rot": 0, "shape": "rounded", "radius": 18, "bg": "#ffffff", "accent": "#30ba78", "fit": "cover", "text": "Priya Nair\n{w200|CTO}", "fg": "#0c322c", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 },
          { "id": "coo", "kind": "card", "layout": "row", "x": 650, "y": 430, "w": 300, "h": 116, "rot": 0, "shape": "rounded", "radius": 18, "bg": "#ffffff", "accent": "#30ba78", "fit": "cover", "text": "Sam Osei\n{w200|COO}", "fg": "#0c322c", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 },
          { "id": "cfo", "kind": "card", "layout": "row", "x": 940, "y": 430, "w": 300, "h": 116, "rot": 0, "shape": "rounded", "radius": 18, "bg": "#ffffff", "accent": "#30ba78", "fit": "cover", "text": "Mia Chen\n{w200|CFO}", "fg": "#0c322c", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 },
          { "id": "eng1", "kind": "card", "layout": "icon", "x": 210, "y": 740, "w": 280, "h": 92, "rot": 0, "shape": "rounded", "radius": 14, "bg": "#ffffff", "accent": "#30ba78", "text": "Platform\n{w200|Infrastructure team}", "fg": "#0c322c", "fontSize": 24, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.14, "pad": 14 },
          { "id": "eng2", "kind": "card", "layout": "icon", "x": 520, "y": 740, "w": 280, "h": 92, "rot": 0, "shape": "rounded", "radius": 14, "bg": "#ffffff", "accent": "#fe7c3f", "text": "Product\n{w200|Application team}", "fg": "#0c322c", "fontSize": 24, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.14, "pad": 14 }
        ],
        "connectors": [
          { "id": "c1", "from": "ceo", "to": "cto", "style": "elbow", "arrow": "end", "head": "open", "dash": "solid", "color": "#30ba78", "width": 3.5 },
          { "id": "c2", "from": "ceo", "to": "coo", "style": "elbow", "arrow": "end", "head": "open", "dash": "solid", "color": "#30ba78", "width": 3.5 },
          { "id": "c3", "from": "ceo", "to": "cfo", "style": "elbow", "arrow": "end", "head": "open", "dash": "solid", "color": "#30ba78", "width": 3.5 },
          { "id": "c4", "from": "cto", "to": "eng1", "style": "elbow", "arrow": "end", "head": "open", "dash": "solid", "color": "#30ba78", "width": 3.5 },
          { "id": "c5", "from": "cto", "to": "eng2", "style": "elbow", "arrow": "end", "head": "open", "dash": "solid", "color": "#30ba78", "width": 3.5 }
        ]
      }
    }
  ],
  "render": {
    "width": 1600,
    "height": 1000,
    "formats": ["png", "svg", "pdf", "jpg", "webp"],
    "actions": ["copy", "download", "save", "share"],
    "layout": "editor",
    "transparentBg": true,
    "printMarks": false
  },
  "hooks": { "onInit": true, "onInput": true },
  "inputs": [
    {
      "id": "background",
      "type": "color",
      "label": "Canvas background",
      "default": "#f4f7f6"
    },
    {
      "id": "boxes",
      "type": "blocks",
      "label": "Cards",
      "labelledFields": true,
      "addMenu": { "field": "kind", "label": "Add card" },
      "canvas": {
        "idField": "id",
        "xField": "x",
        "yField": "y",
        "wField": "w",
        "hField": "h",
        "rotationField": "rot",
        "shapeField": "shape",
        "radiusField": "radius",
        "fillField": "bg",
        "opacityField": "opacity",
        "imageField": "image",
        "imgPosField": "imgpos",
        "textField": "text",
        "textColorField": "fg",
        "fontSizeField": "fontSize",
        "alignField": "align",
        "valignField": "valign",
        "weightField": "weight",
        "fontField": "font",
        "lineHeightField": "lineHeight",
        "trackingField": "tracking",
        "ligaturesField": "ligatures",
        "alternatesField": "alternates",
        "padField": "pad",
        "blendField": "blend",
        "groupField": "group",
        "clipField": "clip",
        "shadowField": "shadow",
        "shadowColorField": "shadowColor",
        "shadowXField": "shadowX",
        "shadowYField": "shadowY",
        "shadowBlurField": "shadowBlur",
        "minSize": 8,
        "fixedCanvas": true,
        "grid": { "size": 20, "default": true },
        "connect": {
          "input": "connectors",
          "fromField": "from",
          "toField": "to",
          "styleField": "style",
          "arrowField": "arrow",
          "headField": "head",
          "colorField": "color",
          "dashField": "dash",
          "widthField": "width",
          "layerClass": "oc-connectors",
          "defaultStyle": "elbow",
          "defaultArrow": "end",
          "defaultHead": "open",
          "defaultColor": "#30ba78",
          "defaultWidth": 3.5
        },
        "addKinds": [
          { "id": "card", "label": "Person", "seed": { "kind": "card", "layout": "row", "shape": "rounded", "radius": 18, "bg": "#ffffff", "accent": "#30ba78", "fit": "cover", "text": "New person\n{w200|Job title}", "fg": "#0c322c", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 } },
          { "id": "role", "label": "Role", "seed": { "kind": "card", "layout": "icon", "shape": "rounded", "radius": 14, "bg": "#ffffff", "accent": "#30ba78", "text": "Team\n{w200|What they do}", "fg": "#0c322c", "fontSize": 24, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.14, "pad": 14 } },
          { "id": "photo", "label": "Photo card", "seed": { "kind": "card", "layout": "stacked", "shape": "rounded", "radius": 18, "bg": "#ffffff", "accent": "#30ba78", "fit": "cover", "text": "Name\n{w200|Title}", "fg": "#0c322c", "fontSize": 26, "align": "center", "valign": "top", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 } },
          { "id": "text", "label": "Text", "seed": { "kind": "text", "layout": "plain", "bg": "", "shape": "rect", "text": "Heading", "fg": "#0c322c", "fontSize": 44, "valign": "top", "weight": "700", "font": "SUSE", "lineHeight": 1.12, "pad": 8 } },
          { "id": "box", "label": "Box", "seed": { "kind": "box", "layout": "plain", "bg": "#30BA78", "shape": "rounded", "radius": 16, "text": "" } },
          { "id": "image", "label": "Image", "seed": { "kind": "image", "layout": "plain", "bg": "#eef1f0", "shape": "rounded", "fit": "contain", "text": "" } }
        ]
      },
      "fields": [
        { "id": "id", "type": "text" },
        {
          "id": "kind",
          "type": "select",
          "label": "Kind",
          "default": "card",
          "options": [
            { "value": "card", "label": "Person / card", "repeatable": true },
            { "value": "text", "label": "Text", "repeatable": true },
            { "value": "box", "label": "Box", "repeatable": true },
            { "value": "image", "label": "Image", "repeatable": true }
          ]
        },
        {
          "id": "layout",
          "type": "select",
          "label": "Card layout",
          "default": "row",
          "help": "How a card arranges its photo/icon and text. Headshot-left and icon-left put the image beside the text; Photo-on-top stacks them; Plain is a bare box (image fills it, text overlays).",
          "options": [
            { "value": "row", "label": "Headshot left" },
            { "value": "icon", "label": "Icon left" },
            { "value": "stacked", "label": "Photo on top" },
            { "value": "plain", "label": "Plain box" }
          ]
        },
        { "id": "x", "type": "number", "label": "X", "default": 640 },
        { "id": "y", "type": "number", "label": "Y", "default": 440 },
        { "id": "w", "type": "number", "label": "Width", "default": 300, "min": 1 },
        { "id": "h", "type": "number", "label": "Height", "default": 116, "min": 1 },
        { "id": "rot", "type": "number", "label": "Rotation", "default": 0, "min": -180, "max": 180 },
        {
          "id": "shape",
          "type": "select",
          "label": "Shape",
          "default": "rounded",
          "options": [
            { "value": "rect", "label": "Rectangle" },
            { "value": "rounded", "label": "Rounded" },
            { "value": "pill", "label": "Pill" },
            { "value": "ellipse", "label": "Ellipse" }
          ]
        },
        { "id": "radius", "type": "number", "label": "Corner radius", "default": 16, "min": 0, "showIf": { "shape": "rounded" } },
        { "id": "bg", "type": "color", "label": "Card fill", "default": "#ffffff" },
        { "id": "accent", "type": "color", "label": "Accent", "default": "#30ba78", "help": "The avatar ring / icon chip / initials colour on a card." },
        { "id": "opacity", "type": "number", "label": "Opacity", "default": 100, "min": 0, "max": 100, "display": "slider" },
        { "id": "image", "type": "asset", "label": "Photo or icon", "assetType": "any", "allowUpload": true, "help": "A headshot, logo or icon. On a card it sits in the avatar; without one, the card shows the person's initials." },
        {
          "id": "fit",
          "type": "select",
          "label": "Image fit",
          "default": "cover",
          "options": [
            { "value": "contain", "label": "Contain (fit inside)" },
            { "value": "cover", "label": "Cover (crop to fill)" },
            { "value": "fill", "label": "Stretch" }
          ]
        },
        {
          "id": "blend",
          "type": "select",
          "label": "Blend mode",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "multiply", "label": "Multiply" },
            { "value": "screen", "label": "Screen" },
            { "value": "overlay", "label": "Overlay" },
            { "value": "darken", "label": "Darken" },
            { "value": "lighten", "label": "Lighten" }
          ]
        },
        { "id": "text", "type": "text", "label": "Text", "default": "", "multilineFor": ["card", "box", "text", "image"], "rows": 3, "help": "First line is the name (make it **bold**); following lines are the title/detail. Rich text: **bold**, *italic*, and lines starting with - become bullets." },
        { "id": "fg", "type": "color", "label": "Text colour", "default": "#0c322c" },
        { "id": "fontSize", "type": "number", "label": "Text size", "default": 30, "min": 4 },
        {
          "id": "align",
          "type": "select",
          "label": "Align",
          "default": "left",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Centre" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "id": "valign",
          "type": "select",
          "label": "Vertical",
          "default": "middle",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "id": "weight",
          "type": "select",
          "label": "Weight",
          "default": "500",
          "options": [
            { "value": "200", "label": "Extra light" },
            { "value": "300", "label": "Light" },
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semibold" },
            { "value": "700", "label": "Bold" },
            { "value": "800", "label": "Extrabold" }
          ]
        },
        {
          "id": "font",
          "type": "select",
          "label": "Font",
          "default": "SUSE",
          "options": [
            { "value": "SUSE", "label": "SUSE Sans" },
            { "value": "SUSE Mono", "label": "SUSE Mono" }
          ]
        },
        { "id": "lineHeight", "type": "number", "label": "Line height", "default": 1.15, "min": 0.7, "max": 3, "step": 0.05 },
        { "id": "tracking", "type": "number", "label": "Kerning", "default": 0, "min": -100, "max": 400, "step": 0.5 },
        { "id": "ligatures", "type": "boolean", "label": "Ligatures", "default": true },
        { "id": "alternates", "type": "boolean", "label": "Stylistic alternates", "default": false },
        { "id": "group", "type": "text", "label": "Group", "default": "" },
        { "id": "clip", "type": "text", "label": "Clip to", "default": "" },
        { "id": "pad", "type": "number", "label": "Padding", "default": 16, "min": 0 },
        {
          "id": "shadow",
          "type": "select",
          "label": "Shadow",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "box", "label": "Box" },
            { "value": "text", "label": "Text" },
            { "value": "content", "label": "Content" }
          ]
        },
        { "id": "shadowColor", "type": "color", "label": "Shadow colour", "default": "#0c322c33" },
        { "id": "shadowX", "type": "number", "label": "Shadow X", "default": 0, "min": -300, "max": 300 },
        { "id": "shadowY", "type": "number", "label": "Shadow Y", "default": 6, "min": -300, "max": 300 },
        { "id": "shadowBlur", "type": "number", "label": "Shadow blur", "default": 18, "min": 0, "max": 300 },
        {
          "id": "imgpos",
          "type": "select",
          "label": "Image position",
          "default": "center",
          "options": [
            { "value": "left top", "label": "Top left" },
            { "value": "center top", "label": "Top" },
            { "value": "right top", "label": "Top right" },
            { "value": "left center", "label": "Left" },
            { "value": "center", "label": "Centre" },
            { "value": "right center", "label": "Right" },
            { "value": "left bottom", "label": "Bottom left" },
            { "value": "center bottom", "label": "Bottom" },
            { "value": "right bottom", "label": "Bottom right" }
          ]
        }
      ],
      "default": [
        { "id": "ceo", "kind": "card", "layout": "row", "x": 650, "y": 90, "w": 300, "h": 116, "rot": 0, "shape": "rounded", "radius": 18, "bg": "#0c322c", "accent": "#30ba78", "fit": "cover", "text": "Alex Rivera\n{w200|Chief Executive}", "fg": "#ffffff", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 },
        { "id": "cto", "kind": "card", "layout": "row", "x": 360, "y": 430, "w": 300, "h": 116, "rot": 0, "shape": "rounded", "radius": 18, "bg": "#ffffff", "accent": "#30ba78", "fit": "cover", "text": "Priya Nair\n{w200|CTO}", "fg": "#0c322c", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 },
        { "id": "coo", "kind": "card", "layout": "row", "x": 650, "y": 430, "w": 300, "h": 116, "rot": 0, "shape": "rounded", "radius": 18, "bg": "#ffffff", "accent": "#30ba78", "fit": "cover", "text": "Sam Osei\n{w200|COO}", "fg": "#0c322c", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 },
        { "id": "cfo", "kind": "card", "layout": "row", "x": 940, "y": 430, "w": 300, "h": 116, "rot": 0, "shape": "rounded", "radius": 18, "bg": "#ffffff", "accent": "#30ba78", "fit": "cover", "text": "Mia Chen\n{w200|CFO}", "fg": "#0c322c", "fontSize": 30, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.15, "pad": 16 },
        { "id": "eng1", "kind": "card", "layout": "icon", "x": 210, "y": 740, "w": 280, "h": 92, "rot": 0, "shape": "rounded", "radius": 14, "bg": "#ffffff", "accent": "#30ba78", "text": "Platform\n{w200|Infrastructure team}", "fg": "#0c322c", "fontSize": 24, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.14, "pad": 14 },
        { "id": "eng2", "kind": "card", "layout": "icon", "x": 520, "y": 740, "w": 280, "h": 92, "rot": 0, "shape": "rounded", "radius": 14, "bg": "#ffffff", "accent": "#fe7c3f", "text": "Product\n{w200|Application team}", "fg": "#0c322c", "fontSize": 24, "align": "left", "valign": "middle", "weight": "500", "font": "SUSE", "lineHeight": 1.14, "pad": 14 }
      ]
    },
    {
      "id": "connectors",
      "type": "blocks",
      "label": "Connectors",
      "labelledFields": true,
      "fields": [
        { "id": "id", "type": "text" },
        { "id": "from", "type": "text", "label": "From card" },
        { "id": "to", "type": "text", "label": "To card" },
        {
          "id": "style",
          "type": "select",
          "label": "Line style",
          "default": "elbow",
          "options": [
            { "value": "straight", "label": "Straight" },
            { "value": "elbow", "label": "Elbow — auto" },
            { "value": "elbow-v", "label": "Elbow — vertical" },
            { "value": "elbow-h", "label": "Elbow — horizontal" },
            { "value": "elbow-src", "label": "Elbow — bend at start" },
            { "value": "elbow-tgt", "label": "Elbow — bend at end" },
            { "value": "curved", "label": "Curved — auto S" },
            { "value": "curved-v", "label": "Curved — vertical S" },
            { "value": "curved-h", "label": "Curved — horizontal S" },
