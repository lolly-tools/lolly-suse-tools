{
  "id": "d3",
  "name": "D3 Chart Studio",
  "description": "Powerful data-driven charts with D3 — paste a table and it charts itself. Bars, lines, areas, scatter, pie, radar, treemap, heatmap and more, on-brand and vector-clean.",
  "version": "1.1.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "designer",
  "a11yLabel": "{{chartType}} chart{{#if heading}} — {{heading}}{{/if}}",
  "tags": [
    "chart",
    "d3",
    "data",
    "visualization",
    "graph",
    "plot",
    "bar",
    "line",
    "area",
    "scatter",
    "pie",
    "donut",
    "radar",
    "treemap",
    "heatmap",
    "histogram",
    "svg",
    "vector",
    "csv"
  ],
  "featured": {
    "order": 4,
    "blurb": "Paste a table — D3 charts it, on-brand and vector-clean"
  },
  "render": {
    "width": 1280,
    "height": 800,
    "formats": [
      "md",
      "png",
      "svg",
      "emf",
      "pdf",
      "pdf-cmyk",
      "cmyk-tiff",
      "tiff",
      "pptx",
      "webp",
      "jpg"
    ],
    "actions": [
      "copy",
      "download",
      "save"
    ],
    "transparentBg": false
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "examples": [
    {
      "label": "Grouped bars",
      "values": {
        "chartType": "bar",
        "stackMode": "grouped",
        "heading": "Revenue by product line",
        "subheading": "€M per quarter — illustrative sample data",
        "palette": "suse",
        "background": "#ffffff",
        "showLegend": true,
        "data": "Quarter,SLES,Rancher,Edge\nQ1,42,28,12\nQ2,49,35,18\nQ3,55,41,24\nQ4,63,52,33"
      }
    },
    {
      "label": "Stacked area",
      "values": {
        "chartType": "area",
        "stackMode": "stacked",
        "curve": "monotone",
        "heading": "GPU hours across the AI pipeline",
        "subheading": "Thousands of hours — illustrative sample data",
        "palette": "cool",
        "background": "#0c322c",
        "textColor": "#ffffff",
        "showLegend": true,
        "data": "Month,Inference,Training,Retrieval\nJan,4.6,2.8,0.9\nFeb,5.1,3.0,1.1\nMar,6.0,3.4,1.4\nApr,7.2,3.1,1.8\nMay,8.4,4.0,2.2"
      }
    },
    {
      "label": "Donut",
      "values": {
        "chartType": "donut",
        "donutRadius": 0.58,
        "heading": "Edge fleet by site type",
        "subheading": "Share of nodes — illustrative sample data",
        "palette": "suse",
        "background": "#ffffff",
        "showLegend": true,
        "legendPosition": "right",
        "showValues": true,
        "data": "Site,Nodes\nRetail,340\nManufacturing,270\nTelco,210\nBranch,110\nLogistics,70"
      }
    },
    {
      "label": "Multi-line",
      "values": {
        "chartType": "line",
        "curve": "monotone",
        "showPoints": true,
        "heading": "Community growth by region",
        "subheading": "New contributors — illustrative sample data",
        "palette": "suse",
        "background": "#ffffff",
        "showLegend": true,
        "data": "Year,EMEA,Americas,APAC\n2021,120,96,64\n2022,180,140,110\n2023,260,205,170\n2024,340,270,250"
      }
    },
    {
      "label": "Treemap",
      "values": {
        "chartType": "treemap",
        "heading": "Open-source contributions",
        "subheading": "By project — illustrative sample data",
        "palette": "pine",
        "background": "#ffffff",
        "showValues": true,
        "data": "Project,Commits\nRancher,4200\nK3s,2600\nLonghorn,1800\nNeuVector,1400\nHarvester,1100\nElemental,600"
      }
    },
    {
      "label": "Scatter",
      "values": {
        "chartType": "scatter",
        "pointSize": 14,
        "fillOpacity": 70,
        "heading": "Cluster size vs. cost",
        "subheading": "One dot per cluster — illustrative sample data",
        "palette": "waterhole",
        "background": "#ffffff",
        "xTitle": "Nodes",
        "yTitle": "Monthly cost (€K)",
        "data": "Cluster,Nodes,Cost,Users\nA,12,4.2,120\nB,28,9.1,260\nC,54,16.5,540\nD,41,12.0,410\nE,7,2.1,70\nF,63,22.4,600"
      }
    }
  ],
