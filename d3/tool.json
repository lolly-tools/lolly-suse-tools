          "label": "Icicle"
        },
        {
          "value": "chord",
          "label": "Chord"
        }
      ]
    },
    {
      "id": "data",
      "urlKey": "d",
      "label": "Paste your table",
      "type": "longtext",
      "rows": 9,
      "placeholder": "Quarter,SLES,Rancher,Edge\nQ1,42,28,12\nQ2,49,35,18",
      "help": "Copy cells straight from Excel, Google Sheets or Numbers and paste here — they come across as a clean table (no fiddling with commas). Or type/paste CSV or TSV. First row = column headers; the first text column becomes the labels and every numeric column a series. The chart rebuilds automatically.",
      "default": "Quarter,SLES,Rancher,Edge\nQ1,42,28,12\nQ2,49,35,18\nQ3,55,41,24\nQ4,63,52,33"
    },
    {
      "id": "hasHeader",
      "urlKey": "hh",
      "label": "First row is a header",
      "section": "Data",
      "type": "boolean",
      "default": true
    },
    {
      "id": "delimiter",
      "urlKey": "dl",
      "label": "Column separator",
      "section": "Data",
      "type": "select",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "Auto-detect"
        },
        {
          "value": "comma",
          "label": "Comma  ,"
        },
        {
          "value": "tab",
          "label": "Tab"
        },
        {
          "value": "semicolon",
          "label": "Semicolon  ;"
        },
        {
          "value": "pipe",
          "label": "Pipe  |"
        }
      ]
    },
    {
      "id": "transpose",
      "urlKey": "tp",
      "label": "Swap rows & columns",
      "section": "Data",
      "type": "boolean",
      "default": false,
      "help": "Flip the table so the header row becomes the categories and each row becomes a series."
    },
    {
      "id": "labelColumn",
      "urlKey": "lc",
      "label": "Label column",
      "section": "Columns",
      "type": "text",
      "default": "",
      "placeholder": "auto (first column)",
      "help": "Which column holds the category / x-axis labels — a column name or its number (1 = first). Blank = the first column."
    },
    {
      "id": "seriesColumns",
      "urlKey": "sc",
      "label": "Series columns",
      "section": "Columns",
      "type": "text",
      "default": "",
      "placeholder": "auto (all numeric)",
      "help": "Which columns to plot, comma-separated (names or numbers), in the order you list them. Blank = every numeric column."
    },
    {
      "id": "pivotColumn",
      "urlKey": "pv",
      "label": "Pivot by column",
      "section": "Columns",
      "type": "text",
      "default": "",
      "placeholder": "auto (for long data)",
      "help": "For long / tidy data (one row per observation): the column whose values become the separate series. Blank = auto-detect."
    },
    {
      "id": "stackMode",
      "urlKey": "sm",
      "label": "Series layout",
      "section": "Chart",
      "type": "select",
      "default": "grouped",
      "options": [
        {
          "value": "grouped",
          "label": "Grouped (side by side)"
        },
        {
          "value": "stacked",
          "label": "Stacked"
        },
        {
          "value": "stacked100",
          "label": "Stacked 100%"
        }
      ],
      "showIf": {
        "chartType": [
          "bar",
          "bar-horizontal",
          "area"
        ]
      }
    },
    {
      "id": "curve",
      "urlKey": "cv",
      "label": "Line shape",
      "section": "Chart",
      "type": "select",
      "default": "monotone",
      "options": [
        {
          "value": "linear",
          "label": "Straight"
        },
        {
          "value": "monotone",
          "label": "Smooth (monotone)"
        },
        {
          "value": "natural",
          "label": "Smooth (natural)"
        },
        {
          "value": "catmullRom",
          "label": "Smooth (Catmull–Rom)"
        },
        {
          "value": "cardinal",
          "label": "Smooth (cardinal)"
        },
        {
          "value": "basis",
          "label": "Smooth (basis)"
        },
        {
          "value": "step",
          "label": "Step (mid)"
        },
        {
          "value": "stepBefore",
          "label": "Step (before)"
        },
        {
          "value": "stepAfter",
          "label": "Step (after)"
        },
        {
          "value": "bumpX",
          "label": "Bump"
        }
      ],
      "showIf": {
        "chartType": [
          "line",
          "area"
        ]
      }
    },
    {
      "id": "showPoints",
      "urlKey": "pt",
      "label": "Show point markers",
      "section": "Chart",
      "type": "boolean",
      "default": false,
      "showIf": {
        "chartType": [
          "line",
          "area"
        ]
      }
    },
    {
      "id": "pointSize",
      "urlKey": "ps",
      "label": "Point size",
      "section": "Chart",
      "type": "number",
      "display": "slider",
      "default": 10,
      "min": 2,
      "max": 48,
      "step": 1,
      "showIf": {
        "chartType": [
          "scatter",
          "line",
          "area",
          "slope",
          "bump",
          "dumbbell",
          "lollipop"
        ]
      }
    },
    {
      "id": "sizeBy",
      "urlKey": "sz",
      "label": "Bubble size",
