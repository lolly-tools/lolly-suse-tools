    {
      "label": "Product launch · portrait · 4 blocks",
      "values": {
        "width": 1080, "height": 1350,
        "blocks": [
          { "kind": "logo", "logoOrient": "horizontal", "logoColor": "mono", "bgColor": "#0c322c", "logoSize": 0.8 },
          { "kind": "heading", "text": "Choice.", "bgColor": "#30ba78", "fgColor": "#0c322c", "scale": 1.2, "weight": 900 },
          { "kind": "subheading", "text": "Open source, your way", "bgColor": "#bff1ea", "fgColor": "#0c322c", "scale": 1, "weight": 500 },
