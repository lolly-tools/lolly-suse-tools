{
  "id": "pose-geeko",
  "name": "Pose Geeko",
  "description": "Pose the SUSE Geeko with sliders — eyes, blink and limbs. No animation, just a still you can dial in and export print-ready.",
  "version": "0.1.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "designer",
  "new": true,
  "tags": ["geeko", "mascot", "pose", "illustration", "svg"],
  "hooks": { "onInit": true, "onInput": true, "beforeExport": true },
  "render": {
    "width": 800,
    "height": 800,
    "formats": ["svg", "pdf", "dxf", "cmyk-tiff", "jpg"],
    "actions": ["download", "copy", "save"]
  },
  "featured": {
    "order": 2,
    "blurb": "Pose the SUSE Geeko — print-ready stills",
    "variants": [
      {
        "label": "Curious climb · transparent",
        "values": {
          "pose": "curious",
          "foliage": 26,
          "eyeX": -34,
          "eyeY": -18,
          "headTilt": 7,
          "blink": 0,
          "bg": "transparent",
          "geeko": { "scale": 1.06, "x": -5, "y": 3 }
        }
      },
      {
        "label": "Sitting · on dark",
        "values": {
          "pose": "sitting",
          "tail": -18,
          "blink": 8,
          "eyeX": 46,
          "eyeY": 8,
          "headTilt": -5,
          "bg": "dark",
          "geeko": { "scale": 0.9, "x": 2, "y": 10 }
        }
      },
      {
        "label": "Dangling · flipped",
        "values": {
          "pose": "dangling",
          "legFront": 58,
          "legBack": -28,
          "headTilt": -9,
          "flip": true,
          "eyeX": 70,
          "eyeY": -12,
          "bg": "light",
          "geeko": { "scale": 1.28, "x": 9, "y": -7 }
        }
      },
      {
        "label": "Laying · light",
        "values": {
          "pose": "laying",
          "blink": 66,
          "headTilt": 12,
          "eyeY": 40,
          "bg": "light",
          "geeko": { "scale": 0.82, "x": 0, "y": 17 }
        }
      },
      {
        "label": "Sitting · transparent",
        "values": {
          "pose": "sitting",
          "tail": 3,
          "eyeX": 92,
          "eyeY": -12,
          "blink": 0,
          "bg": "transparent",
          "geeko": { "scale": 1, "x": 0, "y": 0 }
        }
      }
    ]
  },
  "inputs": [
    {
      "id": "pose",
      "label": "Geeko",
      "type": "select",
      "default": "curious",
      "options": [
        { "value": "curious",   "label": "Curious" },
        { "value": "sitting",   "label": "Sitting" },
        { "value": "laying",    "label": "Laying" },
        { "value": "dangling",  "label": "Dangling" }
      ]
    },
    {
      "id": "eyeX",
      "label": "Eye left / right",
      "type": "number",
      "display": "slider",
      "section": "Pose",
      "help": "Slides the pupil across the eye. Positive looks right.",
      "min": -100,
      "max": 200,
      "step": 1,
      "default": 0
    },
    {
      "id": "eyeY",
      "label": "Eye up / down",
      "type": "number",
      "display": "slider",
      "section": "Pose",
      "help": "Slides the pupil across the eye. Positive looks down.",
      "min": -100,
      "max": 200,
      "step": 1,
      "default": 0
    },
    {
      "id": "blink",
      "label": "Blink",
      "type": "number",
      "display": "slider",
      "section": "Pose",
      "help": "0 = wide awake, higher = eyes shut.",
      "min": 0,
      "max": 300,
      "step": 1,
      "default": 0,
      "showIf": { "pose": ["curious", "sitting", "laying"] },
      "rangeWhen": [
        { "when": { "pose": "curious" }, "min": 0, "max": 100 },
        { "when": { "pose": "sitting" }, "min": 0, "max": 100 }
      ]
    },
    {
      "id": "headTilt",
      "label": "Head tilt",
      "type": "number",
      "display": "slider",
      "section": "Pose",
      "help": "Tilts the Geeko's head.",
      "min": -30,
      "max": 30,
      "step": 1,
      "default": 0,
      "rangeWhen": [
        { "when": { "pose": "laying" },   "min": -14, "max": 18 },
        { "when": { "pose": "dangling" }, "min": -14, "max": 9 }
      ]
    },
    {
      "id": "foliage",
      "label": "Leaves & branch",
      "type": "number",
      "display": "slider",
      "section": "Pose",
      "help": "Rotates the branch and leaves. Climbing pose.",
      "min": -40,
      "max": 40,
      "step": 1,
      "default": 0,
      "showIf": { "pose": "curious" }
    },
    {
      "id": "legFront",
      "label": "Front leg",
      "type": "number",
      "display": "slider",
      "section": "Pose",
      "help": "Swings the front leg. Dangling pose.",
      "min": -30,
      "max": 80,
      "step": 1,
      "default": 0,
      "showIf": { "pose": "dangling" }
    },
    {
      "id": "legBack",
      "label": "Back leg",
      "type": "number",
      "display": "slider",
      "section": "Pose",
      "help": "Swings the back leg. Dangling pose.",
      "min": -45,
      "max": 45,
      "step": 1,
      "default": 0,
      "showIf": { "pose": "dangling" }
    },
    {
      "id": "tail",
      "label": "Tail curl",
      "type": "number",
      "display": "slider",
      "section": "Pose",
      "help": "Curls the tail. Sitting pose.",
      "min": -22,
      "max": 10,
      "step": 1,
      "default": 0,
      "showIf": { "pose": "sitting" }
    },
    {
      "id": "geeko",
      "label": "Scale & Position",
      "section": "Geeko Options",
      "help": "Scale sizes Geeko; X / Y nudge it in the frame (%). Drag a label or type a value.",
      "type": "vector",
      "fields": [
        { "id": "scale", "label": "Scale", "min": 0.25, "max": 3,   "step": 0.05, "default": 1 },
        { "id": "x",     "label": "X",     "min": -100, "max": 100, "step": 1,    "default": 0 },
        { "id": "y",     "label": "Y",     "min": -100, "max": 100, "step": 1,    "default": 0 }
      ]
    },
    {
      "id": "flip",
      "label": "Flip Geeko",
      "type": "boolean",
      "section": "Geeko Options",
      "default": false
    },
    {
      "id": "idle",
      "label": "Idle motion",
      "help": "A gentle breathing loop on screen. Turn off for a dead-still pose. Never affects the exported still (SVG/PDF/TIFF/JPG snapshot one frame).",
      "type": "boolean",
      "section": "Geeko Options",
      "default": true
    },
    {
      "id": "bg",
      "label": "Background",
      "type": "select",
      "section": "Geeko Options",
      "default": "transparent",
      "options": [
        { "value": "transparent", "label": "Transparent" },
        { "value": "dark",   "label": "Dark" },
        { "value": "light",  "label": "Light" },
        { "value": "pine",   "label": "Pine" }
      ]
    }
  ]
}
