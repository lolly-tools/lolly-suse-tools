{
  "id": "diagram-builder",
  "name": "Diagram Builder",
  "description": "Org charts, flowcharts, timelines and more — from cards, text, Mermaid or CSV.",
  "a11yLabel": "{{default title \"Untitled\"}} — {{diagramType}} diagram",
  "version": "1.4.0",
  "engineVersion": "^1.0.0",
  "status": "experimental",
  "category": "everyone",
  "tags": ["diagram", "org-chart", "org chart", "architecture", "layercake", "flowchart", "process", "hierarchy", "mind map", "mindmap", "timeline", "roadmap", "cycle", "pyramid", "funnel", "kanban", "matrix", "quadrant", "gantt", "cards", "arrows", "ascii", "text", "mermaid", "csv"],
  "featured": {
    "order": 6,
    "blurb": "Turn cards or text into on-brand diagrams"
  },
  "examples": [
    { "label": "Org · SUSE dark", "values": { "diagramType": "org", "theme": "suse-dark", "orgDir": "down", "title": "Leadership Team", "cardLayout": "row", "background": "#0c322c", "nodeFill": "#0c322c", "nodeStroke": "#90ebcd", "nodeText": "#ffffff", "edgeColor": "#90ebcd" } },
    { "label": "Mind map · dark", "values": { "diagramType": "mindmap", "theme": "suse-dark", "branchColors": true, "title": "Product Roadmap", "cardLayout": "stacked", "background": "#0c322c", "nodeText": "#ffffff", "edgeColor": "#90ebcd" } },
    { "label": "Cycle · blueprint", "values": { "diagramType": "cycle", "theme": "blueprint", "cycleCurved": true, "gridBg": "grid", "title": "Delivery Lifecycle", "cardLayout": "stacked", "background": "#0a2540", "nodeFill": "#0a2540", "nodeStroke": "#7fd4ff", "nodeText": "#eaf6ff", "edgeColor": "#7fd4ff" } },
    { "label": "Process · SUSE dark", "values": { "diagramType": "process", "theme": "suse-dark", "flowDir": "right", "title": "CI/CD Pipeline", "cardLayout": "stacked", "background": "#0c322c", "nodeFill": "#0c322c", "nodeStroke": "#90ebcd", "nodeText": "#ffffff", "edgeColor": "#90ebcd" } },
    { "label": "Layercake · mint", "values": { "diagramType": "layercake", "theme": "mint", "title": "Platform Architecture", "cardLayout": "stacked", "background": "#eafaf4", "nodeFill": "#ffffff", "nodeStroke": "#0c322c", "nodeText": "#0c322c", "edgeColor": "#0c322c" } },
    { "label": "Pyramid · mint", "values": { "diagramType": "pyramid", "pyramidStyle": "pyramid", "theme": "mint", "title": "Adoption Model", "cardLayout": "stacked", "background": "#eafaf4", "nodeFill": "#ffffff", "nodeStroke": "#0c322c", "nodeText": "#0c322c", "edgeColor": "#0c322c" } },
    { "label": "Timeline · blueprint", "values": { "diagramType": "timeline", "timelineDir": "right", "theme": "blueprint", "gridBg": "grid", "title": "Release Timeline", "cardLayout": "stacked", "background": "#0a2540", "nodeFill": "#0a2540", "nodeStroke": "#7fd4ff", "nodeText": "#eaf6ff", "edgeColor": "#7fd4ff" } },
    { "label": "Org · fog light", "values": { "diagramType": "org", "theme": "suse-light", "orgDir": "down", "title": "Company Structure", "cardLayout": "row", "background": "#ffffff", "nodeFill": "#ffffff", "nodeStroke": "#0c322c", "nodeText": "#0c322c", "edgeColor": "#30ba78" } }
  ],
  "render": {
    "width": 1600,
    "height": 1000,
    "formats": ["svg", "pdf", "dxf", "png"],
    "actions": ["copy", "download", "save"],
    "transparentBg": true
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "preset",
      "label": "Preset",
      "type": "select",
      "default": "custom",
      "help": "A one-click starting point that seeds the type, theme and spacing. Pick one, then fine-tune anything — your later edits are kept.",
      "options": [
        { "value": "custom", "label": "Custom" },
        { "value": "org-classic", "label": "Org — classic" },
        { "value": "layercake-mint", "label": "Layercake — SUSE mint" },
        { "value": "process-lr", "label": "Process — left to right" },
        { "value": "blueprint", "label": "Blueprint" },
        { "value": "mono", "label": "Minimal mono" }
      ]
    },
    {
      "id": "diagramType",
      "label": "Diagram type",
      "type": "select",
      "default": "org",
      "help": "Org/Mind map build a tree from each card's parent. Layercake/Kanban group cards by their “Group” ID (stacked bands vs side-by-side columns). Process/Timeline/Cycle lay cards out along flow/order. Pyramid, Matrix and Gantt have their own controls below.",
      "options": [
        { "value": "org", "label": "Org chart (hierarchy)" },
        { "value": "mindmap", "label": "Mind map" },
        { "value": "layercake", "label": "Layercake (layered architecture)" },
        { "value": "kanban", "label": "Kanban / columns" },
        { "value": "process", "label": "Process (flowchart)" },
        { "value": "timeline", "label": "Timeline" },
        { "value": "cycle", "label": "Cycle (loop)" },
        { "value": "pyramid", "label": "Pyramid / funnel" },
        { "value": "matrix", "label": "Matrix (2×2 quadrant)" },
        { "value": "gantt", "label": "Gantt / roadmap" }
      ]
    },
    {
      "id": "source",
      "label": "Build from",
      "type": "select",
      "default": "visual",
      "help": "Visual edits cards as form rows. Text renders a typed description. ASCII art traces boxes you draw. Mermaid pastes a graph TD/LR subset. Table reads a pasted CSV.",
      "options": [
        { "value": "visual", "label": "Visual editor" },
        { "value": "text", "label": "Text (type it)" },
        { "value": "ascii", "label": "ASCII art (draw it)" },
        { "value": "mermaid", "label": "Mermaid (paste it)" },
        { "value": "table", "label": "Table / CSV (paste it)" }
      ]
    },

    { "id": "theme", "label": "Theme", "type": "select", "default": "custom", "section": "Style", "help": "Seeds the colours below. Pick one, then override any individual colour.", "options": [ { "value": "custom", "label": "Custom" }, { "value": "suse-light", "label": "SUSE light" }, { "value": "suse-dark", "label": "SUSE dark" }, { "value": "blueprint", "label": "Blueprint" }, { "value": "mono", "label": "Mono" }, { "value": "mint", "label": "Mint" } ] },
    { "id": "cardLayout", "label": "Card layout", "type": "select", "default": "row", "section": "Style", "help": "How each card arranges its image and text. Side by side puts the image on the left with left-aligned text — a card with no image uses the full width. Image on top stacks a centred image above centred text.", "options": [ { "value": "row", "label": "Side by side (image left)" }, { "value": "stacked", "label": "Image on top" } ] },
    { "id": "nodeFill", "label": "Card fill", "type": "color", "default": "#ffffff", "section": "Style" },
    { "id": "nodeStroke", "label": "Card border", "type": "color", "default": "#0c322c", "section": "Style" },
    { "id": "cardBorderWidth", "label": "Card border width", "type": "number", "display": "slider", "min": 0, "max": 6, "step": 0.5, "default": 2, "section": "Style", "help": "0 = borderless cards." },
    { "id": "nodeText", "label": "Card text", "type": "color", "default": "#0c322c", "section": "Style" },
    { "id": "labelSize", "label": "Label size", "type": "number", "display": "slider", "min": 10, "max": 28, "step": 1, "default": 10, "section": "Style" },
    { "id": "labelWeight", "label": "Label weight", "type": "number", "display": "slider", "min": 100, "max": 900, "step": 100, "default": 500, "section": "Style", "help": "Font weight of the card labels (100 Thin → 900 Black)." },
    { "id": "edgeColor", "label": "Connectors", "type": "color", "default": "#0c322c", "section": "Style", "help": "Colour of the automatic connectors / spines." },
    { "id": "connectorWidth", "label": "Connector width", "type": "number", "display": "slider", "min": 0.3, "max": 6, "step": 0.1, "default": 2.6, "section": "Style" },
    { "id": "background", "label": "Background", "type": "color", "default": "#ffffff", "section": "Style", "help": "Set to Transparent for a knock-out background." },
    { "id": "gridBg", "label": "Background pattern", "type": "select", "default": "dots", "section": "Style", "options": [ { "value": "none", "label": "None" }, { "value": "dots", "label": "Dots" }, { "value": "grid", "label": "Grid" } ] },

    { "id": "density", "label": "Density", "type": "select", "default": "cozy", "section": "Layout", "help": "Seeds the spacing + card scale below. Pick one, then nudge the sliders.", "options": [ { "value": "custom", "label": "Custom" }, { "value": "compact", "label": "Compact" }, { "value": "cozy", "label": "Cozy" }, { "value": "comfortable", "label": "Comfortable" }, { "value": "spacious", "label": "Spacious" } ] },
    { "id": "cardWidth", "label": "Card width", "type": "number", "display": "slider", "min": 120, "max": 320, "step": 4, "default": 148, "section": "Layout" },
    { "id": "cardScale", "label": "Card scale", "type": "number", "display": "slider", "min": 0.6, "max": 1.6, "step": 0.05, "default": 1, "section": "Layout", "help": "Scales card size, padding and text together." },
    { "id": "rowGap", "label": "Row / layer gap", "type": "number", "display": "slider", "min": 0, "max": 200, "step": 4, "default": 56, "section": "Layout", "help": "Spacing along the flow (levels, ranks, bands)." },
    { "id": "siblingGap", "label": "Sibling gap", "type": "number", "display": "slider", "min": 0, "max": 160, "step": 2, "default": 30, "section": "Layout", "help": "Spacing between neighbours within a level." },
    { "id": "cornerRadius", "label": "Corner radius", "type": "number", "display": "slider", "min": 0, "max": 28, "step": 1, "default": 14, "section": "Layout", "help": "Roundness of “Rounded” cards (Box and Pill keep their shape)." },
    { "id": "canvasPadding", "label": "Canvas padding", "type": "number", "display": "slider", "min": 0, "max": 160, "step": 4, "default": 44, "section": "Layout", "help": "Whitespace around the diagram." },

    {
      "id": "title",
      "label": "Title",
      "type": "text",
      "default": "",
      "placeholder": "Optional heading shown above the diagram"
    },

    {
      "id": "orgDir",
      "label": "Direction",
      "type": "select",
      "default": "down",
      "showIf": { "diagramType": "org" },
      "help": "Lay the tree top-to-bottom, or left-to-right for deep hierarchies.",
      "options": [
        { "value": "down", "label": "Top to bottom" },
        { "value": "right", "label": "Left to right" }
      ]
    },
    {
      "id": "mindmapStyle",
      "label": "Branch layout",
      "type": "select",
      "default": "balanced",
      "showIf": { "diagramType": "mindmap" },
      "options": [
        { "value": "balanced", "label": "Balanced (both sides)" },
        { "value": "right", "label": "Right only" }
      ]
    },
    {
      "id": "branchColors",
      "label": "Colour by branch",
      "type": "boolean",
      "default": true,
      "showIf": { "diagramType": "mindmap" },
      "help": "Tint each top-level branch with its own palette colour."
    },
    {
      "id": "flowDir",
      "label": "Flow direction",
      "type": "select",
      "default": "down",
      "showIf": { "diagramType": "process" },
      "help": "Which way a process flows between steps.",
      "options": [
        { "value": "down", "label": "Top to bottom" },
        { "value": "right", "label": "Left to right" }
      ]
    },
    {
      "id": "timelineDir",
      "label": "Direction",
      "type": "select",
      "default": "right",
      "showIf": { "diagramType": "timeline" },
      "options": [
        { "value": "right", "label": "Left to right" },
        { "value": "down", "label": "Top to bottom" }
      ]
    },
    {
      "id": "cycleArrows",
      "label": "Show loop arrows",
      "type": "boolean",
      "default": true,
      "showIf": { "diagramType": "cycle" }
    },
    {
      "id": "cycleCurved",
      "label": "Curved arrows",
      "type": "boolean",
      "default": true,
      "showIf": { "diagramType": "cycle" },
      "help": "Bow the ring arrows outward instead of straight chords."
    },
    {
      "id": "pyramidStyle",
      "label": "Style",
      "type": "select",
      "default": "pyramid",
      "showIf": { "diagramType": "pyramid" },
      "help": "Cards are listed top→bottom. Pyramid widens downward, funnel narrows, inverted widens upward.",
      "options": [
        { "value": "pyramid", "label": "Pyramid (wide base)" },
        { "value": "funnel", "label": "Funnel (narrowing)" },
        { "value": "inverted", "label": "Inverted pyramid" }
      ]
    },
    {
      "id": "kanbanCount",
      "label": "Show card counts",
      "type": "boolean",
      "default": false,
      "showIf": { "diagramType": "kanban" }
    },
    {
      "id": "matrixXHigh",
      "label": "X axis — high",
      "type": "text",
      "default": "",
      "placeholder": "e.g. High impact",
      "showIf": { "diagramType": "matrix" }
    },
    {
      "id": "matrixXLow",
      "label": "X axis — low",
      "type": "text",
      "default": "",
      "placeholder": "e.g. Low impact",
      "showIf": { "diagramType": "matrix" }
    },
    {
      "id": "matrixYHigh",
      "label": "Y axis — high",
      "type": "text",
      "default": "",
      "placeholder": "e.g. High effort",
      "showIf": { "diagramType": "matrix" }
    },
    {
      "id": "matrixYLow",
      "label": "Y axis — low",
      "type": "text",
      "default": "",
      "placeholder": "e.g. Low effort",
      "showIf": { "diagramType": "matrix" }
    },
    {
      "id": "ganttGrid",
      "label": "Show time grid",
      "type": "boolean",
      "default": true,
      "showIf": { "diagramType": "gantt" }
    },
    {
      "id": "ganttUnit",
      "label": "Time unit label",
      "type": "text",
      "default": "",
      "placeholder": "e.g. wk",
      "showIf": { "diagramType": "gantt" }
    },

    {
      "id": "dsl",
      "label": "Diagram text",
      "type": "longtext",
      "showIf": { "source": "text" },
      "help": "Org/Mind map: indent for hierarchy. Layercake/Kanban: “# Group” headings with cards below. Process/Gantt: “A -> B” (Gantt adds “ : 0..3”). Timeline/Cycle/Pyramid: one item per line, in order. Matrix: “# top-right” sections or “Item @ (0.8,0.3)”. Shared: “:: subtitle”, “#hex” fill, “(Rounded)”/“[Box]”/“([Pill])” shape, “@ https://…/logo.png” image, edge styles --> -.-> ==> <->, “// comment”.",
      "default": "CEO\n  CTO :: Technology\n    Eng Lead\n    QA Lead\n  CFO :: Finance\n  COO :: Operations"
    },
    {
      "id": "asciiArt",
      "label": "ASCII art",
      "type": "longtext",
      "showIf": { "source": "ascii" },
      "help": "Draw boxes with + - | and connect them with - | and arrowheads > < ^ v. Keep each box's | sides lined up with its +---+ borders. The first line inside a box is its title, the rest its subtitle, and a line of “@ https://…/logo.png” adds an image. Your layout is preserved — we just render it as clean cards.",
      "default": "+--------+          +-------+\n| Client |--------->|  API  |\n+--------+          +-------+\n                        |\n                        v\n                  +----------+\n                  | Database |\n                  +----------+"
    },
    {
      "id": "mermaid",
      "label": "Mermaid",
      "type": "longtext",
      "showIf": { "source": "mermaid" },
      "help": "Paste a Mermaid flowchart subset. “graph TD/LR” sets direction; A[Box], A(Rounded), A([Pill]), A{Diamond} define nodes; A-->B, A---B, A-.->B, A==>B, A-->|label|B are edges; subgraph Name … end becomes layer bands. Unsupported lines (classDef, click, style…) are skipped, never run.",
      "default": "graph LR\n  A[Client] --> B(API Gateway)\n  B --> C[(Database)]\n  B -.-> D{{Cache}}"
    },
    {
      "id": "table",
      "label": "Table / CSV",
      "type": "longtext",
      "showIf": { "source": "table" },
      "help": "Paste comma- or tab-separated rows. Org/Mind map: id,label,detail,parent. Process: from,to,label (an edge list — ids are created automatically). Timeline/Cycle/Pyramid: label,detail. A header row (id/label/from/…) is detected and skipped.",
      "default": "id,label,parent\nceo,CEO,\ncto,CTO,ceo\ncfo,CFO,ceo\neng,Eng Lead,cto\nqa,QA Lead,cto"
    },

    {
      "id": "nodes",
      "label": "Cards",
      "type": "blocks",
      "labelledFields": true,
      "showIf": { "source": "visual" },
      "help": "One card per row. In org / mind map, drag a card onto another to nest it — drop above or below to make it a sibling, or onto the middle to make it a child. Elsewhere, drag to reorder (order sets sibling order, layer/column order, and the sequence for timeline/cycle/pyramid/gantt). The ID is an optional short handle.",
      "addMenu": { "field": "shape", "label": "Add card" },
      "nesting": { "parentField": "parent", "keyField": "nodeId", "labelField": "label", "activeWhen": { "diagramType": ["org", "mindmap"] } },
      "fields": [
        {
          "id": "shape",
          "label": "Shape",
          "type": "select",
          "default": "rounded",
          "options": [
            { "value": "box", "label": "Box", "repeatable": true },
            { "value": "rounded", "label": "Rounded", "repeatable": true },
            { "value": "pill", "label": "Pill", "repeatable": true }
          ]
        },
        { "id": "label", "label": "Label", "type": "text", "placeholder": "Card text" },
        { "id": "fill", "label": "Card colour", "type": "color", "default": "", "help": "Overrides the global card fill for this card only." },
        { "id": "image", "label": "Image", "type": "asset", "assetType": "any", "allowUpload": true, "help": "Optional headshot, icon, or product logo shown on the card." },
        { "id": "nodeId", "label": "ID", "type": "text", "placeholder": "e.g. ceo", "help": "Short unique handle. Auto-derived from the label if left blank." },
        { "id": "detail", "label": "Detail", "type": "text", "placeholder": "Subtitle (optional)" },
        { "id": "parent", "label": "Reports to", "default": "", "optionsFrom": { "input": "nodes", "value": "nodeId", "label": "label", "excludeSelf": true, "excludeDescendants": true, "emptyLabel": "— Top level —" }, "help": "Org / mind map: the card this one reports to / branches from. Pick a card, or just drag this row onto another in the list." },
        { "id": "layer", "label": "Group", "default": "", "optionsFrom": { "input": "layers", "value": "layerId", "label": "label", "prefix": "layer-", "freeText": true, "emptyLabel": "— none —" }, "help": "Layercake: which band. Kanban: which column — pick one, or type a new name to create a column. Cards in the same group sit together." },
        { "id": "quadrant", "label": "Quadrant", "type": "select", "default": "tr", "showIf": { "diagramType": "matrix" }, "options": [ { "value": "tr", "label": "Top-right" }, { "value": "tl", "label": "Top-left" }, { "value": "br", "label": "Bottom-right" }, { "value": "bl", "label": "Bottom-left" } ] },
        { "id": "ganttStart", "label": "Start", "type": "number", "min": 0, "max": 1000, "step": 0.5, "showIf": { "diagramType": "gantt" }, "help": "Bar start on the time axis." },
        { "id": "ganttLen", "label": "Length", "type": "number", "min": 0.5, "max": 1000, "step": 0.5, "showIf": { "diagramType": "gantt" }, "help": "Bar length in the same units." }
      ],
      "default": [
        { "shape": "rounded", "nodeId": "ceo",   "label": "CEO",                   "detail": "DP Van Leeuwen", "parent": "",      "layer": "experience", "fill": "", "image": { "source": "library", "id": "suse/headshots/dirk-peter-van-leeuwen" } },
        { "shape": "rounded", "nodeId": "ceo-2", "label": "CAISO",                 "detail": "Frank Feldmann", "parent": "ceo",   "layer": "CAISO",      "fill": "", "image": { "source": "library", "id": "suse/headshots/frank-feldmann" } },
        { "shape": "rounded", "nodeId": "CAISO", "label": "Corporate Development", "detail": "Charlie Metz",   "parent": "ceo-2", "layer": "",           "fill": "", "image": { "source": "library", "id": "suse/headshots/charlie-metz" } },
        { "shape": "rounded", "nodeId": "",      "label": "CIO",                   "detail": "Jochen Jasser",  "parent": "ceo-2", "layer": "",           "fill": "", "image": { "source": "library", "id": "suse/headshots/jochen-jaser" } },
        { "shape": "rounded", "nodeId": "quality-execution", "label": "Lolly's Dad", "detail": "Andy Fitzsimon", "parent": "ceo-2", "layer": "", "fill": "", "image": { "source": "library", "id": "suse/headshots/andy-fitzsimon" } },
        { "shape": "rounded", "nodeId": "",      "label": "Sovereign Solutions",   "detail": "Andreas Prins",  "parent": "ceo-2", "layer": "",           "fill": "", "image": { "source": "library", "id": "suse/headshots/andreas-prins" } },
        { "shape": "rounded", "nodeId": "",      "label": "EPMO",                  "detail": "Frank Rego",     "parent": "ceo-2", "layer": "",           "fill": "" }
      ]
    },
    {
      "id": "layers",
      "label": "Layers / columns (in order)",
      "type": "blocks",
      "labelledFields": true,
      "showIf": { "source": "visual", "diagramType": "layercake" },
      "help": "Each band of the layercake, stacked in this order. Cards reference a band by its ID. (Kanban columns are created automatically from each card's Group ID.)",
      "addMenu": { "field": "kind", "label": "Add layer" },
      "fields": [
        { "id": "kind", "label": "Kind", "type": "select", "default": "layer", "options": [ { "value": "layer", "label": "Layer", "repeatable": true } ] },
        { "id": "layerId", "label": "ID", "type": "text", "placeholder": "e.g. experience" },
        { "id": "label", "label": "Label", "type": "text", "placeholder": "e.g. Experience" },
        { "id": "bandFill", "label": "Band colour", "type": "color", "default": "#efefef" }
      ],
      "default": [
        { "kind": "layer", "layerId": "experience", "label": "Experience", "bandFill": "#90ebcd" },
        { "kind": "layer", "layerId": "services", "label": "Services", "bandFill": "#bff1ea" },
        { "kind": "layer", "layerId": "data", "label": "Data", "bandFill": "#efefef" }
      ]
    },
    {
      "id": "arrows",
      "label": "Flow arrows",
      "type": "blocks",
      "labelledFields": true,
      "showIf": { "source": "visual" },
      "help": "In process/gantt these arrows ARE the flow / dependencies. In org/layercake/etc they're extra arrows on top of the automatic connectors. Pick the cards (or layers) each arrow runs between.",
      "fields": [
        { "id": "from", "label": "From", "default": "", "optionsFrom": { "sources": [ { "input": "nodes", "value": "nodeId", "label": "label" }, { "input": "layers", "value": "layerId", "label": "label", "prefix": "layer-" } ], "emptyLabel": "— choose —" } },
        { "id": "to", "label": "To", "default": "", "optionsFrom": { "sources": [ { "input": "nodes", "value": "nodeId", "label": "label" }, { "input": "layers", "value": "layerId", "label": "label", "prefix": "layer-" } ], "emptyLabel": "— choose —" } },
        { "id": "label", "label": "Label", "type": "text", "placeholder": "optional" },
        { "id": "style", "label": "Line", "type": "select", "default": "solid", "options": [ { "value": "solid", "label": "Solid" }, { "value": "dashed", "label": "Dashed" }, { "value": "dotted", "label": "Dotted" } ] },
