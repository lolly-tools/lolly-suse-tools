        ]
      }
    },
    {
      "label": "Ship faster · skinny · 3 blocks",
      "values": {
        "width": 820, "height": 1440,
        "blocks": [
          { "kind": "heading", "text": "Ship faster.", "bgColor": "#0c322c", "fgColor": "#30ba78", "scale": 1.4, "weight": 900 },
          { "kind": "subheading", "text": "Enterprise Linux, delivered", "bgColor": "#fe7c3f", "fgColor": "#ffffff", "scale": 1, "weight": 600 },
