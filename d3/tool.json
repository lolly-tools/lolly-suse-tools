          "label": "Bar — vertical"
        },
        {
          "value": "bar-horizontal",
          "label": "Bar — horizontal"
        },
        {
          "value": "line",
          "label": "Line"
        },
        {
          "value": "area",
          "label": "Area"
        },
        {
          "value": "scatter",
          "label": "Scatter / bubble"
        },
        {
          "value": "pie",
          "label": "Pie"
        },
        {
          "value": "donut",
          "label": "Donut"
        },
        {
          "value": "radial-bar",
